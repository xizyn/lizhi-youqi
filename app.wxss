page {
  min-height: 100vh;
  color: #2f332b;
  background: #f7f2e8;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

view,
text,
input,
textarea,
button {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 56rpx;
}

.section {
  margin-top: 28rpx;
}

.section-title {
  color: #25331e;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.25;
}

.section-subtitle {
  margin-top: 8rpx;
  color: #6a6f5f;
  font-size: 25rpx;
}

.card {
  padding: 28rpx;
  border: 1rpx solid rgba(70, 112, 51, 0.12);
  border-radius: 16rpx;
  background: #fffdf6;
  box-shadow: 0 8rpx 24rpx rgba(66, 81, 41, 0.06);
}

.soft-card {
  padding: 24rpx;
  border-radius: 16rpx;
  background: #eef6e5;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.tag {
  padding: 6rpx 18rpx;
  border: 1rpx solid rgba(58, 103, 45, 0.18);
  border-radius: 999rpx;
  color: #3d6c30;
  background: #f5fbef;
  font-size: 23rpx;
  line-height: 1.5;
}

.tag-red {
  border-color: rgba(183, 55, 49, 0.16);
  color: #a93531;
  background: #fff1ec;
}

.muted {
  color: #6a6f5f;
}

.strong {
  color: #25331e;
  font-weight: 700;
}

.button-stack {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 28rpx;
}

.action-btn {
  width: 100%;
  height: 88rpx;
  border: 0;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 88rpx;
}

.action-btn::after {
  border: 0;
}

.primary-btn {
  color: #fffdf8;
  background: #b83b37;
}

.green-btn {
  color: #fffdf8;
  background: #3f7335;
}

.plain-btn {
  color: #335f2e;
  background: #edf6e7;
}

.white-btn {
  color: #32472a;
  background: #fffdf7;
  border: 1rpx solid rgba(70, 112, 51, 0.18);
}

.mini-btn {
  height: 64rpx;
  padding: 0 22rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  line-height: 64rpx;
}

.mini-btn::after {
  border: 0;
}

.form-card {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 24rpx;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.field-label {
  color: #35412d;
  font-size: 26rpx;
  font-weight: 700;
}

.field-input,
.field-textarea,
.picker-value {
  width: 100%;
  min-height: 82rpx;
  padding: 20rpx 22rpx;
  border: 1rpx solid rgba(63, 115, 53, 0.18);
  border-radius: 14rpx;
  color: #2f332b;
  background: #fffdf7;
  font-size: 28rpx;
}

.field-textarea {
  min-height: 168rpx;
}

.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-value::after {
  content: "";
  width: 14rpx;
  height: 14rpx;
  margin-left: 16rpx;
  border-right: 3rpx solid #7a826f;
  border-bottom: 3rpx solid #7a826f;
  transform: rotate(45deg) translateY(-4rpx);
}

.notice {
  padding: 22rpx;
  border-left: 8rpx solid #b83b37;
  border-radius: 14rpx;
  color: #5d3d31;
  background: #fff2eb;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 20rpx;
}

.list-item {
  padding: 22rpx;
  border-radius: 14rpx;
  background: #fffdf7;
}

.empty {
  padding: 44rpx 24rpx;
  border: 1rpx dashed rgba(63, 115, 53, 0.28);
  border-radius: 16rpx;
  color: #7a826f;
  text-align: center;
  background: rgba(255, 253, 247, 0.72);
}

.page-skeleton {
  position: fixed;
  z-index: 900;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  padding: 28rpx;
  background: #f7f2e8;
}

.skeleton-card {
  margin-bottom: 20rpx;
  padding: 26rpx;
  border: 1rpx solid rgba(63, 115, 53, 0.08);
  border-radius: 18rpx;
  background: #fffdf7;
}

.skeleton-line,
.skeleton-block {
  overflow: hidden;
  border-radius: 10rpx;
  background: #e8eee2;
  animation: skeleton-fade 1.2s ease-in-out infinite;
}

.skeleton-line {
  height: 24rpx;
  margin-top: 16rpx;
}

.skeleton-line:first-child {
  margin-top: 0;
}

.skeleton-line.short {
  width: 38%;
}

.skeleton-line.medium {
  width: 68%;
}

.skeleton-block {
  height: 150rpx;
  margin-top: 20rpx;
}

.export-loading-mask {
  position: fixed;
  z-index: 1200;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: rgba(36, 48, 32, 0.42);
}

.export-loading-card {
  width: 420rpx;
  padding: 38rpx 30rpx;
  border-radius: 20rpx;
  background: #fffdf7;
  box-shadow: 0 20rpx 60rpx rgba(33, 48, 28, 0.18);
  text-align: center;
}

.export-loading-dots {
  display: flex;
  justify-content: center;
  gap: 12rpx;
}

.export-loading-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #4f7d46;
  animation: loading-dot 0.9s ease-in-out infinite;
}

.export-loading-dot:nth-child(2) {
  animation-delay: 0.15s;
}

.export-loading-dot:nth-child(3) {
  animation-delay: 0.3s;
}

.export-loading-text {
  margin-top: 22rpx;
  color: #2f472b;
  font-size: 27rpx;
  font-weight: 700;
}

.export-loading-note {
  margin-top: 8rpx;
  color: #7a826f;
  font-size: 21rpx;
}

@keyframes skeleton-fade {
  0%,
  100% {
    opacity: 0.55;
  }
  50% {
    opacity: 1;
  }
}

@keyframes loading-dot {
  0%,
  60%,
  100% {
    transform: translateY(0);
    opacity: 0.45;
  }
  30% {
    transform: translateY(-8rpx);
    opacity: 1;
  }
}
