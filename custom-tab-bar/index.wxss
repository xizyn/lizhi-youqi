.tabbar-host {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 999;
  padding: 0 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: transparent;
  box-sizing: border-box;
}

.tabbar-card {
  display: flex;
  align-items: center;
  justify-content: space-around;
  height: 82rpx;
  border: 1rpx solid rgba(92, 112, 70, 0.1);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -6rpx 28rpx rgba(80, 96, 62, 0.1);
}

.tabbar-item {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 82rpx;
  color: #8b9088;
}

.tabbar-icon {
  width: 32rpx;
  height: 32rpx;
}

.tabbar-text {
  margin-top: 4rpx;
  font-size: 20rpx;
  line-height: 1.2;
}

.tabbar-item.selected-true {
  color: #4f7d46;
}
