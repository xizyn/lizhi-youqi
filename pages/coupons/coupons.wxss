.member-page {
  padding: 48rpx 30rpx 130rpx;
  background: #faf5eb;
}

.page-head {
  padding: 28rpx 0 20rpx;
}

.page-title {
  color: #25331e;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.3;
}

.page-subtitle {
  margin-top: 10rpx;
  color: #7a826f;
  font-size: 24rpx;
  line-height: 1.5;
}

.coupon-tabs {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-bottom: 22rpx;
}

.coupon-tab {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 66rpx;
  border-radius: 999rpx;
  border: 1rpx solid #e5ddce;
  color: #315f2d;
  background: #f5efe4;
  font-size: 24rpx;
  font-weight: 700;
}

.coupon-tab.active {
  color: #fffdf8;
  background: #3f7335;
}

.empty-state {
  padding: 70rpx 24rpx;
  border: 1rpx solid rgba(79,125,70,.1);
  border-radius: 18rpx;
  background: #fffdf6;
  text-align: center;
}

.empty-title { color: #25331e; font-size: 29rpx; font-weight: 800; }
.empty-desc { margin-top: 10rpx; color: #7a826f; font-size: 23rpx; }
.empty-btn { width: 280rpx; height: 68rpx; margin-top: 26rpx; border-radius: 999rpx; color: #fff; background: #3f7335; font-size: 23rpx; font-weight: 700; line-height: 68rpx; }
.empty-btn::after { border: 0; }

.coupon-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.coupon-card {
  display: flex;
  overflow: hidden;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #eef7e8 0%, #fffdf7 100%);
  box-shadow: 0 12rpx 28rpx rgba(80, 96, 62, 0.08);
}

.coupon-card.status-expired {
  opacity: 0.58;
}

.coupon-card.status-used {
  background: linear-gradient(135deg, #f5f1e8 0%, #fffdf7 100%);
}

.coupon-main {
  flex: 1;
  padding: 28rpx 24rpx;
}

.coupon-title {
  color: #2f7d42;
  font-size: 32rpx;
  font-weight: 800;
}

.coupon-desc,
.coupon-time {
  margin-top: 8rpx;
  color: #6f7a65;
  font-size: 23rpx;
}

.coupon-side {
  display: flex;
  flex: 0 0 150rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 248, 237, 0.82);
}

.coupon-amount {
  color: #c05a20;
  font-size: 38rpx;
  font-weight: 800;
}

.coupon-status {
  margin-top: 8rpx;
  color: #7a826f;
  font-size: 22rpx;
}

.claim-btn {
  width: 104rpx;
  height: 48rpx;
  margin-top: 12rpx;
  border-radius: 999rpx;
  color: #fffdf8;
  background: #3f7335;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 48rpx;
}

.claim-btn::after {
  border: 0;
}
