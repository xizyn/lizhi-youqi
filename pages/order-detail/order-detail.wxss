.detail-page {
  min-height: 100vh;
  padding: 34rpx 28rpx 130rpx;
  background: #f8f3e9;
  box-sizing: border-box;
}

.detail-head,
.section-card {
  border-radius: 18rpx;
  background: #fffdf7;
  box-shadow: 0 10rpx 26rpx rgba(80, 96, 62, 0.06);
}

.detail-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding: 24rpx;
}

.order-no {
  color: #25331e;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
}

.head-subtitle {
  margin-top: 8rpx;
  color: #7a826f;
  font-size: 23rpx;
  line-height: 1.5;
}

.order-status,
.status-text {
  flex: 0 0 auto;
  padding: 7rpx 16rpx;
  border-radius: 999rpx;
  color: #3f7335;
  background: #eef6e7;
  font-size: 22rpx;
  font-weight: 700;
}

.section-card {
  margin-top: 20rpx;
  padding: 24rpx;
}

.section-title {
  color: #25331e;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.3;
}

.status-row {
  margin-top: 16rpx;
}

.status-tip {
  margin-top: 12rpx;
  color: #7a826f;
  font-size: 23rpx;
  line-height: 1.45;
}

.info-row {
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(82, 111, 65, 0.1);
}

.info-row:last-child {
  border-bottom: 0;
}

.info-label {
  flex: 0 0 auto;
  color: #6f7a65;
  font-size: 24rpx;
}

.info-value {
  min-width: 0;
  color: #25331e;
  font-size: 25rpx;
  line-height: 1.45;
  text-align: right;
  word-break: break-all;
}

.amount-value {
  color: #8d3d38;
  font-weight: 800;
}

.status-paid {
  color: #2f6f3a;
  background: #e4f5e8;
}

.status-pending-delivery {
  color: #b37a00;
  background: #fff3d6;
}

.status-picking {
  color: #7a5d3f;
  background: #f0e6d6;
}

.status-shipped {
  color: #1f5f9f;
  background: #e4f1ff;
}

.status-done {
  color: #4f7d46;
  background: #eef8ea;
}

.status-cancelled {
  color: #737970;
  background: #eef0ea;
}

.status-service {
  color: #c0392b;
  background: #fdecea;
}

.status-pending-pay {
  color: #8d3d38;
  background: #fff1ec;
}

.status-default {
  color: #3f7335;
  background: #eef6e7;
}

.action-row,
.admin-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.mini-btn {
  flex: 1;
  min-width: 160rpx;
  height: 62rpx;
  margin: 0;
  border-radius: 999rpx;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 62rpx;
}

.mini-btn::after {
  border: 0;
}

.plain-btn {
  color: #3f7335;
  background: #eef6e7;
}

.service-btn {
  color: #8d3d38;
  background: #fff1ec;
}

.admin-card {
  background: #fffaf0;
}

.field {
  margin-top: 18rpx;
}

.field-label {
  margin-bottom: 10rpx;
  color: #53604a;
  font-size: 23rpx;
  font-weight: 700;
}

.picker-value {
  height: 72rpx;
  padding: 0 18rpx;
  border-radius: 14rpx;
  background: #f3ead9;
  color: #25331e;
  font-size: 25rpx;
  line-height: 72rpx;
}

.admin-btn {
  color: #5d4b2f;
  background: #f4ead7;
}
