page {
  background: #f8f5ed;
}

.orders-page {
  width: 100%;
  min-height: 100vh;
  padding: 18rpx 24rpx 150rpx;
  box-sizing: border-box;
  overflow-x: hidden;
  color: #233122;
}

.status-tabs-scroll {
  width: 100%;
  margin-bottom: 22rpx;
  white-space: nowrap;
}

.status-tabs {
  display: inline-flex;
  gap: 10rpx;
  min-width: 100%;
  padding: 4rpx 0;
}

.status-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 7rpx;
  min-width: 88rpx;
  height: 54rpx;
  padding: 0 18rpx;
  box-sizing: border-box;
  border: 1rpx solid #e5e8df;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.86);
  color: #697264;
  font-size: 23rpx;
  line-height: 54rpx;
}

.status-tab.active {
  border-color: #4e8242;
  background: #4e8242;
  color: #ffffff;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(60, 105, 52, 0.18);
}

.status-count {
  min-width: 26rpx;
  height: 26rpx;
  padding: 0 5rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  background: #eef3e9;
  color: #517248;
  font-size: 18rpx;
  line-height: 26rpx;
  text-align: center;
}

.status-tab.active .status-count {
  background: rgba(255, 255, 255, 0.22);
  color: #ffffff;
}

.status-notice {
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-height: 126rpx;
  padding: 24rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(91, 119, 72, 0.08);
  border-radius: 22rpx;
  box-shadow: 0 10rpx 24rpx rgba(72, 87, 56, 0.05);
}

.notice-all,
.notice-processing {
  background: #fff8e7;
}

.notice-pending {
  background: #fff2ee;
}

.notice-shipped {
  background: #edf8ec;
}

.notice-history {
  background: #f2f5f4;
}

.notice-after-sale {
  background: #fff4e9;
}

.notice-icon-wrap {
  display: flex;
  flex: 0 0 66rpx;
  align-items: center;
  justify-content: center;
  width: 66rpx;
  height: 66rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.72);
}

.notice-icon {
  width: 38rpx;
  height: 38rpx;
}

.notice-copy {
  flex: 1;
  min-width: 0;
}

.notice-title {
  color: #263424;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.35;
}

.notice-description {
  margin-top: 7rpx;
  color: #667062;
  font-size: 22rpx;
  line-height: 1.55;
}

.empty-card {
  margin-top: 22rpx;
  padding: 76rpx 28rpx;
  border: 1rpx solid #ecebe5;
  border-radius: 22rpx;
  background: #ffffff;
  text-align: center;
  box-shadow: 0 12rpx 30rpx rgba(73, 86, 60, 0.05);
}

.empty-title {
  color: #344031;
  font-size: 28rpx;
  font-weight: 700;
}

.empty-description {
  margin-top: 12rpx;
  color: #8a9086;
  font-size: 22rpx;
  line-height: 1.55;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 22rpx;
}

.order-card {
  width: 100%;
  max-width: 100%;
  min-width: 0;
  box-sizing: border-box;
  overflow: hidden;
  border: 1rpx solid rgba(89, 106, 75, 0.1);
  border-radius: 22rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 30rpx rgba(73, 86, 60, 0.07);
}

.order-number-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx 24rpx 18rpx;
  border-bottom: 1rpx solid #eef0ea;
}

.order-number {
  overflow: hidden;
  flex: 1;
  color: #4f574d;
  font-size: 22rpx;
  line-height: 1.4;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.copy-link,
.inline-copy {
  flex: 0 0 auto;
  color: #4e8242;
  font-size: 22rpx;
  font-weight: 600;
}

.product-row {
  display: flex;
  gap: 20rpx;
  padding: 22rpx 24rpx;
}

.product-image {
  flex: 0 0 116rpx;
  width: 116rpx;
  height: 116rpx;
  border-radius: 16rpx;
  background: #eef3e8;
}

.product-copy {
  flex: 1;
  min-width: 0;
}

.product-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.product-name {
  overflow: hidden;
  flex: 1;
  color: #1f2b1e;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.35;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-amount {
  flex: 0 0 auto;
  color: #b23f38;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.35;
}

.product-spec {
  margin-top: 9rpx;
  color: #6e766b;
  font-size: 22rpx;
  line-height: 1.45;
}

.product-bottom-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-top: 12rpx;
}

.product-quantity {
  color: #8a9087;
  font-size: 21rpx;
}

.status-badge {
  flex: 0 0 auto;
  padding: 5rpx 13rpx;
  border-radius: 999rpx;
  font-size: 19rpx;
  font-weight: 700;
  line-height: 1.35;
}

.status-pending {
  color: #b44942;
  background: #fff0ec;
}

.status-processing {
  color: #8b681c;
  background: #fff4d9;
}

.status-shipped {
  color: #2f6e95;
  background: #eaf4fb;
}

.status-completed {
  color: #4f7d46;
  background: #edf7e9;
}

.status-cancelled {
  color: #7c827a;
  background: #eff1ee;
}

.status-after-sale {
  color: #b7652f;
  background: #fff0e4;
}

.order-details {
  margin: 0 24rpx;
  border-top: 1rpx solid #edf0e9;
}

.detail-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  min-height: 68rpx;
  padding: 17rpx 0;
  box-sizing: border-box;
  border-bottom: 1rpx solid #f0f1ec;
}

.detail-label {
  flex: 0 0 126rpx;
  color: #6e756b;
  font-size: 22rpx;
  line-height: 1.5;
}

.detail-value {
  flex: 1;
  color: #30392e;
  font-size: 22rpx;
  line-height: 1.5;
  text-align: right;
  word-break: break-all;
}

.detail-value-inline {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
}

.amount-row {
  border-bottom: 0;
}

.amount-value {
  color: #d1453f;
  font-size: 27rpx;
  font-weight: 700;
}

.action-grid {
  display: grid;
  width: 100%;
  min-width: 0;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  padding: 20rpx 24rpx 24rpx;
  box-sizing: border-box;
  border-top: 1rpx solid #edf0e9;
}

.action-grid-one .order-action,
.action-grid-three .action-detail {
  grid-column: 1 / -1;
}

.order-action {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  max-width: 100%;
  min-width: 0;
  height: 62rpx;
  margin: 0;
  padding: 0 10rpx;
  box-sizing: border-box;
  overflow: hidden;
  border: 0;
  border-radius: 12rpx;
  background: #ffffff;
  color: #465044;
  font-size: 21rpx;
  font-weight: 600;
  line-height: 1.2;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
  -webkit-appearance: none;
}

.order-action::after {
  box-sizing: border-box;
  border-width: 1rpx;
  border-color: #dfe3db;
  border-radius: 12rpx;
}

.action-contact,
.action-progress,
.action-logistics {
  color: #44783c;
  background: #fbfef9;
}

.action-contact::after,
.action-progress::after,
.action-logistics::after {
  border-color: #a9c7a2;
}

.action-cancel {
  color: #bd4b45;
  background: #fffdfd;
}

.action-cancel::after {
  border-color: #e9aaa5;
}

.action-after-sale {
  color: #c66f2d;
  background: #fffdf9;
}

.action-after-sale::after {
  border-color: #efbd8d;
}

.order-load-more,
.order-load-end {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  padding: 22rpx 20rpx 8rpx;
  color: #6b7863;
  font-size: 22rpx;
  line-height: 1.5;
}

.order-load-end {
  color: #8b9286;
}

.lychee-loading-dots {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.lychee-loading-dots .dot {
  width: 9rpx;
  height: 9rpx;
  border-radius: 50%;
  background: #4e8242;
  animation: lycheeDotJump 1s ease-in-out infinite;
}

.lychee-loading-dots .delay-1 {
  animation-delay: 0.14s;
}

.lychee-loading-dots .delay-2 {
  animation-delay: 0.28s;
}

@keyframes lycheeDotJump {
  0%,
  80%,
  100% {
    opacity: 0.45;
    transform: translateY(0);
  }

  40% {
    opacity: 1;
    transform: translateY(-5rpx);
  }
}

.page-tip {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 18rpx;
  background: #eef5e8;
  color: #65715e;
  font-size: 21rpx;
  line-height: 1.55;
}

.tip-dot {
  flex: 0 0 14rpx;
  width: 14rpx;
  height: 14rpx;
  margin-top: 9rpx;
  border-radius: 50%;
  background: #78a967;
}
