<view class="address-page">
  <view class="page-head">
    <view class="page-title">常用地址</view>
    <view class="page-subtitle">默认地址会在快递、同城和附近送下单时自动带入。</view>
  </view>

  <view class="empty-card" wx:if="{{addresses.length == 0}}">
    <view class="empty-title">还没有常用地址</view>
    <view class="empty-desc">新增后，下单时会优先使用默认地址。</view>
  </view>

  <view class="address-card" wx:for="{{addresses}}" wx:key="id">
    <view class="address-top">
      <view class="address-name">{{item.name}}</view>
      <view class="address-phone">{{item.phone}}</view>
      <view class="default-tag" wx:if="{{item.isDefault}}">默认</view>
    </view>
    <view class="address-text">{{item.fullAddress}}</view>
    <view class="address-actions">
      <view class="default-action" wx:if="{{!item.isDefault}}" data-id="{{item.id}}" bindtap="setDefault">设为默认</view>
      <view class="default-action active" wx:else>默认地址</view>
      <view class="action-links">
        <view data-id="{{item.id}}" bindtap="openEdit">编辑</view>
        <view class="delete-link" data-id="{{item.id}}" bindtap="deleteAddress">删除</view>
      </view>
    </view>
  </view>

  <button class="add-button" bindtap="openCreate">新增地址</button>

  <view class="editor-mask" wx:if="{{showEditor}}" bindtap="closeEditor">
    <view class="editor-panel" catchtap="stopPropagation">
      <view class="editor-head">
        <view class="editor-title">{{editorTitle}}</view>
        <view class="editor-close" bindtap="closeEditor">×</view>
      </view>
      <view class="form-row">
        <view class="field-label">联系人</view>
        <input value="{{form.name}}" data-field="name" bindinput="handleInput" placeholder="请输入姓名或称呼"></input>
      </view>
      <view class="form-row">
        <view class="field-label">手机号</view>
        <input type="number" maxlength="11" value="{{form.phone}}" data-field="phone" bindinput="handleInput" placeholder="请输入手机号"></input>
      </view>
      <picker mode="region" value="{{form.region}}" bindchange="handleRegionChange">
        <view class="form-row">
          <view class="field-label">省市区</view>
          <view class="picker-text {{form.regionText ? '' : 'placeholder'}}">{{form.regionText || '请选择省 / 市 / 区'}}</view>
        </view>
      </picker>
      <view class="form-row address-input-row">
        <view class="field-label">详细地址</view>
        <textarea maxlength="160" value="{{form.detailAddress}}" data-field="detailAddress" bindinput="handleInput" placeholder="街道、楼栋、门牌号等"></textarea>
      </view>
      <view class="default-switch">
        <view>
          <view class="switch-title">设为默认地址</view>
          <view class="switch-desc">下单时自动选中</view>
        </view>
        <switch checked="{{form.isDefault}}" color="#4f7d46" bindchange="handleDefaultChange"></switch>
      </view>
      <button class="save-button" bindtap="saveAddress">保存地址</button>
    </view>
  </view>
</view>
