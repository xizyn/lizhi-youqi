page {
  background: #faf5eb;
  color: #25331e;
}

.address-page {
  min-height: 100vh;
  padding: 38rpx 28rpx 130rpx;
  box-sizing: border-box;
}

.page-head {
  padding: 20rpx 2rpx 24rpx;
}

.page-title {
  font-size: 38rpx;
  font-weight: 800;
}

.page-subtitle {
  margin-top: 10rpx;
  color: #7a826f;
  font-size: 23rpx;
  line-height: 1.5;
}

.address-card,
.empty-card {
  margin-bottom: 18rpx;
  padding: 28rpx 24rpx;
  border: 1rpx solid rgba(82, 111, 65, 0.1);
  border-radius: 18rpx;
  background: #fffdf7;
  box-shadow: 0 12rpx 28rpx rgba(80, 96, 62, 0.06);
}

.empty-card {
  padding: 70rpx 24rpx;
  text-align: center;
}

.empty-title {
  font-size: 29rpx;
  font-weight: 800;
}

.empty-desc {
  margin-top: 12rpx;
  color: #899083;
  font-size: 23rpx;
}

.address-top,
.address-actions,
.editor-head,
.default-switch {
  display: flex;
  align-items: center;
}

.address-top {
  gap: 14rpx;
}

.address-name {
  font-size: 29rpx;
  font-weight: 800;
}

.address-phone,
.address-text {
  color: #5f6858;
  font-size: 24rpx;
}

.default-tag {
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  color: #2f7d42;
  background: #e7f4df;
  font-size: 20rpx;
}

.address-text {
  margin-top: 14rpx;
  line-height: 1.55;
}

.address-actions {
  justify-content: space-between;
  margin-top: 22rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(82, 111, 65, 0.09);
  font-size: 22rpx;
}

.default-action {
  color: #4f7d46;
}

.default-action.active {
  color: #90968b;
}

.action-links {
  display: flex;
  gap: 30rpx;
  color: #4f7d46;
}

.delete-link {
  color: #9b5d56;
}

button::after {
  border: 0;
}

.add-button,
.save-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 84rpx;
  border: 0;
  border-radius: 15rpx;
  color: #fffdf7;
  background: #4f7d46;
  font-size: 27rpx;
  font-weight: 800;
}

.editor-mask {
  position: fixed;
  z-index: 20;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: flex-end;
  background: rgba(25, 34, 23, 0.42);
}

.editor-panel {
  width: 100%;
  padding: 30rpx 28rpx calc(30rpx + env(safe-area-inset-bottom));
  border-radius: 24rpx 24rpx 0 0;
  background: #fffdf8;
  box-sizing: border-box;
}

.editor-head,
.default-switch {
  justify-content: space-between;
}

.editor-title {
  font-size: 32rpx;
  font-weight: 800;
}

.editor-close {
  color: #848b7f;
  font-size: 42rpx;
}

.form-row {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid #dde3d8;
  border-radius: 14rpx;
  background: #fff;
}

.field-label {
  color: #586451;
  font-size: 22rpx;
}

.form-row input,
.form-row textarea,
.picker-text {
  width: 100%;
  margin-top: 10rpx;
  color: #273323;
  font-size: 26rpx;
}

.form-row textarea {
  height: 100rpx;
}

.placeholder {
  color: #a2a89d;
}

.default-switch {
  margin: 20rpx 2rpx;
}

.switch-title {
  font-size: 25rpx;
  font-weight: 700;
}

.switch-desc {
  margin-top: 5rpx;
  color: #8b9185;
  font-size: 21rpx;
}
