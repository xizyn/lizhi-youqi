<view class="page detail-page">
  <view class="status-card">
    <view class="status-row">
      <view>
        <view class="status-title">{{statusMeta.label}}</view>
        <view class="status-sub">售后编号 {{record.afterSaleId}}</view>
      </view>
      <view class="status-pill status-{{statusMeta.tone}}">{{statusMeta.label}}</view>
    </view>
    <view class="status-facts">
      <view><text>提交时间</text><text>{{record.submittedAt || '未记录'}}</text></view>
      <view><text>售后类型</text><text>{{record.type || '未填写'}}</text></view>
    </view>
    <view class="status-tip">当前为售后沟通记录，客服会根据订单和凭证进行处理。如需实时沟通，可联系微信客服。</view>
  </view>

  <view class="section-card">
    <view class="section-title">原始问题与凭证</view>
    <view class="order-reference">{{record.orderNo}} · {{record.productName}} {{record.specText}}</view>
    <view class="description">{{record.description || '未填写问题描述'}}</view>
    <view class="image-grid" wx:if="{{record.evidenceImages.length}}">
      <image wx:for="{{record.evidenceImages}}" wx:key="*this" src="{{item}}" mode="aspectFill" data-src="{{item}}" bindtap="previewOriginalImage"></image>
    </view>
    <view class="image-empty" wx:else>未提交原始凭证图片</view>
  </view>

  <view class="section-card">
    <view class="section-head">
      <view>
        <view class="section-title">沟通与处理记录</view>
        <view class="section-desc">用于补充凭证和记录处理说明，不提供即时消息功能。</view>
      </view>
      <view class="record-count">{{logs.length}}条</view>
    </view>

    <view class="log-empty" wx:if="{{logs.length == 0}}">暂无补充记录，后续说明会按时间显示在这里。</view>
    <view class="log-timeline" wx:else>
      <view class="log-item log-{{item.roleTone}}" wx:for="{{logs}}" wx:for-index="logIndex" wx:key="id">
        <view class="log-dot"></view>
        <view class="log-card">
          <view class="log-head">
            <view>
              <text class="log-role">{{item.roleLabel}}</text>
              <text class="log-type" wx:if="{{item.recordType}}">{{item.recordType}}</text>
            </view>
            <text class="log-time">{{item.createdAt}}</text>
          </view>
          <view class="log-content" wx:if="{{item.content}}">{{item.content}}</view>
          <view class="log-images" wx:if="{{item.images.length}}">
            <image wx:for="{{item.images}}" wx:for-item="image" wx:key="*this" src="{{image}}" mode="aspectFill" data-src="{{image}}" data-log-index="{{logIndex}}" bindtap="previewLogImage"></image>
          </view>
        </view>
      </view>
    </view>

    <button class="supplement-toggle" bindtap="toggleSupplement">{{supplementOpen ? '收起补充表单' : '补充说明 / 上传凭证'}}</button>

    <view class="supplement-form" wx:if="{{supplementOpen}}">
      <view class="input-head"><text>补充说明</text><text>{{supplementRemaining}}/200</text></view>
      <textarea maxlength="200" value="{{supplementContent}}" bindinput="inputSupplement" placeholder="补充问题情况、数量或希望客服注意的信息"></textarea>
      <view class="input-head image-head"><text>补充图片</text><text>{{supplementImages.length}}/6</text></view>
      <view class="upload-grid">
        <view class="upload-item" wx:for="{{supplementImages}}" wx:key="*this">
          <image src="{{item}}" mode="aspectFill" data-src="{{item}}" bindtap="previewSupplementImage"></image>
          <view class="remove-image" data-index="{{index}}" catchtap="removeSupplementImage">删除</view>
        </view>
        <view class="add-image" wx:if="{{supplementImages.length < 6}}" bindtap="chooseSupplementImages">
          <view class="add-symbol">+</view>
          <view>拍照/相册</view>
        </view>
      </view>
      <button class="submit-supplement" loading="{{submittingSupplement}}" disabled="{{submittingSupplement}}" bindtap="submitSupplement">{{submittingSupplement ? '正在保存' : '保存补充记录'}}</button>
    </view>
  </view>

  <view class="section-card result-card">
    <view class="section-title">当前处理结果</view>
    <view class="result-empty" wx:if="{{!record.adminReply && !record.rejectReason}}">暂无最终处理说明，请留意后续记录。</view>
    <view wx:else>
      <view class="result-type">{{record.resultType || statusMeta.label}}</view>
      <view class="result-copy">{{record.rejectReason || record.adminReply}}</view>
      <view class="info-row" wx:if="{{record.approvedAmount !== ''}}"><text>拟退款金额</text><text>¥{{record.approvedAmount}}</text></view>
      <view class="info-row" wx:if="{{record.offlineRefundStatus}}"><text>退款处理</text><text>{{record.offlineRefundStatus}}</text></view>
      <view class="info-row" wx:if="{{record.replacementInfo}}"><text>补发说明</text><text>{{record.replacementInfo}}</text></view>
    </view>
  </view>

  <view class="local-note">当前为本机演示数据，沟通记录和图片不能跨设备同步，也不会自动通知客服。</view>
  <view class="contact-note">联系人工客服时，请主动提供订单号，方便快速核对处理。</view>
  <view class="action-row">
    <button class="contact-btn" bindtap="contactService">联系微信客服</button>
    <button wx:if="{{canCancel}}" class="cancel-btn" bindtap="cancelApplication">撤销申请</button>
  </view>
</view>
