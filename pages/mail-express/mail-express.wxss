@import "../shared-form.wxss";

.express-order-page {
  padding: 34rpx 24rpx 0;
  box-sizing: border-box;
}

.rule-card,
.section-card,
.transit-card {
  margin-bottom: 22rpx;
  border: 1rpx solid rgba(75, 94, 55, 0.1);
  border-radius: 22rpx;
  background: #fffdf8;
  box-shadow: 0 8rpx 24rpx rgba(57, 74, 44, 0.06);
}

.rule-card {
  overflow: hidden;
  background: #eff6e9;
  box-shadow: none;
}

.rule-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 88rpx;
  padding: 0 22rpx;
}

.rule-copy {
  display: flex;
  align-items: center;
  min-width: 0;
  flex: 1;
}

.rule-icon {
  flex-shrink: 0;
  width: 48rpx;
  height: 48rpx;
  margin-right: 14rpx;
  border-radius: 50%;
  color: #466e40;
  background: #dfeeda;
  font-size: 21rpx;
  line-height: 48rpx;
  text-align: center;
}

.rule-summary-text {
  color: #4e6049;
  font-size: 23rpx;
  line-height: 1.45;
}

.rule-link {
  flex-shrink: 0;
  color: #3f6d3b;
  font-size: 22rpx;
}

.rule-arrow {
  margin-left: 4rpx;
  font-size: 29rpx;
}

.rule-detail {
  padding: 0 24rpx 22rpx 84rpx;
  border-top: 1rpx solid rgba(75, 94, 55, 0.1);
  color: #687663;
  font-size: 22rpx;
  line-height: 1.65;
}

.rule-detail > view:first-child {
  padding-top: 18rpx;
}

.remote-rule {
  margin-top: 10rpx;
  color: #8a6a51;
}

.section-card {
  padding: 26rpx;
}

.section-title {
  margin: 0 0 20rpx;
  color: #263a28;
  font-size: 29rpx;
  font-weight: 700;
}

.product-row {
  display: flex;
  align-items: center;
}

.product-image {
  flex-shrink: 0;
  width: 174rpx;
  height: 140rpx;
  margin-right: 22rpx;
  border-radius: 17rpx;
  background: #eef5e8;
}

.product-info {
  min-width: 0;
  flex: 1;
}

.product-name {
  color: #283a2a;
  font-size: 29rpx;
  font-weight: 650;
}

.product-meta {
  margin-top: 9rpx;
  color: #778172;
  font-size: 22rpx;
  line-height: 1.45;
}

.product-price {
  margin-top: 13rpx;
  color: #b74e45;
  font-size: 29rpx;
  font-weight: 700;
}

.quantity-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #edf0e9;
}

.row-label {
  color: #3f4d40;
  font-size: 25rpx;
}

.row-hint {
  margin-top: 5rpx;
  color: #94998f;
  font-size: 20rpx;
}

.stepper {
  display: flex;
  align-items: center;
  height: 60rpx;
  overflow: hidden;
  border: 1rpx solid #d8e2d2;
  border-radius: 12rpx;
}

.stepper-button {
  width: 60rpx;
  height: 60rpx;
  color: #4f7648;
  background: #f0f6eb;
  font-size: 31rpx;
  line-height: 60rpx;
  text-align: center;
}

.stepper-input {
  width: 70rpx;
  height: 60rpx;
  color: #29372a;
  background: #ffffff;
  font-size: 25rpx;
  line-height: 60rpx;
  text-align: center;
}

.product-summary {
  margin-top: 22rpx;
  padding: 18rpx 20rpx;
  border-radius: 15rpx;
  background: #f5f8f1;
}

.summary-line,
.fee-line,
.fee-total {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.summary-line {
  padding: 6rpx 0;
  color: #4e5a4d;
  font-size: 23rpx;
}

.green-text {
  color: #477442;
  font-weight: 600;
}

.summary-note {
  margin-top: 10rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #e1e8dc;
  color: #81897c;
  font-size: 20rpx;
  line-height: 1.55;
}

.compact-field {
  position: relative;
  display: flex;
  align-items: center;
  min-height: 88rpx;
  border-bottom: 1rpx solid #edf0ea;
}

.field-label {
  flex-shrink: 0;
  width: 150rpx;
  color: #465047;
  font-size: 24rpx;
}

.compact-input,
.picker-value {
  min-width: 0;
  height: 88rpx;
  color: #29372a;
  font-size: 25rpx;
  line-height: 88rpx;
  flex: 1;
}

.placeholder {
  color: #a3a89f;
}

.field-arrow {
  color: #a3a99f;
  font-size: 34rpx;
}

.address-field {
  display: flex;
  padding-top: 24rpx;
}

.address-input {
  min-height: 132rpx;
  padding: 18rpx;
  border: 1rpx solid #e2e8dd;
  border-radius: 14rpx;
  color: #29372a;
  background: #fbfcf9;
  font-size: 24rpx;
  line-height: 1.55;
  box-sizing: border-box;
  flex: 1;
}

.remote-tip {
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  border-radius: 13rpx;
  color: #8a664c;
  background: #fff5e9;
  font-size: 21rpx;
  line-height: 1.55;
}

.note-input {
  width: 100%;
  min-height: 150rpx;
  padding: 20rpx;
  border: 1rpx solid #e2e8dd;
  border-radius: 15rpx;
  color: #29372a;
  background: #fbfcf9;
  font-size: 24rpx;
  line-height: 1.55;
  box-sizing: border-box;
}

.fee-line {
  min-height: 70rpx;
  border-bottom: 1rpx solid #edf0ea;
  color: #4b564b;
  font-size: 24rpx;
}

.fee-total {
  padding-top: 22rpx;
  color: #29382b;
  font-size: 28rpx;
  font-weight: 650;
}

.fee-total text:last-child {
  color: #3f793f;
  font-size: 35rpx;
  font-weight: 700;
}

.fee-tip {
  margin-top: 16rpx;
  color: #838a7e;
  font-size: 21rpx;
  line-height: 1.55;
}

.transit-card {
  padding: 22rpx 24rpx;
  background: #f0f6e9;
  box-shadow: none;
}

.transit-title {
  color: #456640;
  font-size: 24rpx;
  font-weight: 650;
}

.transit-text {
  margin-top: 7rpx;
  color: #6e7969;
  font-size: 21rpx;
  line-height: 1.55;
}

.bottom-placeholder {
  height: 170rpx;
}

.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #e5e7df;
  background: rgba(255, 252, 246, 0.98);
  box-shadow: 0 -8rpx 28rpx rgba(53, 66, 46, 0.08);
}

.submit-total {
  min-width: 0;
  flex: 1;
}

.submit-label {
  color: #747d70;
  font-size: 21rpx;
}

.submit-price {
  margin-top: 4rpx;
  color: #3f793f;
  font-size: 31rpx;
  font-weight: 700;
}

.submit-bar .submit-button {
  width: 260rpx;
  margin: 0;
  border-radius: 18rpx;
}
