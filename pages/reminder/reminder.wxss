page {
  background: #f8f4eb;
  color: #273323;
}

.reminder-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 80rpx;
  box-sizing: border-box;
}

.reminder-hero {
  position: relative;
  height: 390rpx;
  overflow: hidden;
  border-radius: 24rpx;
  background: #eaf3e3;
}

.hero-image,
.hero-overlay {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.hero-overlay {
  background: linear-gradient(90deg, rgba(237, 246, 229, 0.97) 0%, rgba(237, 246, 229, 0.82) 48%, rgba(237, 246, 229, 0.08) 100%);
}

.hero-copy {
  position: absolute;
  left: 32rpx;
  bottom: 34rpx;
  width: 68%;
}

.hero-tag,
.stage-badge,
.reservation-tag,
.update-stage {
  display: inline-flex;
  align-items: center;
  min-height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  color: #2f6d39;
  background: #e5f2dd;
  font-size: 21rpx;
  font-weight: 700;
}

.hero-title {
  margin-top: 16rpx;
  color: #214b2a;
  font-size: 43rpx;
  font-weight: 800;
  line-height: 1.25;
}

.hero-desc {
  margin-top: 14rpx;
  color: #566653;
  font-size: 23rpx;
  line-height: 1.6;
}

.demo-notice {
  margin-top: 18rpx;
  padding: 18rpx 22rpx;
  border-radius: 14rpx;
  color: #795f3d;
  background: #fff3d9;
  font-size: 23rpx;
  line-height: 1.55;
}

.section-block,
.faq-section {
  margin-top: 20rpx;
  padding: 28rpx 24rpx;
  border: 1rpx solid rgba(73, 101, 56, 0.1);
  border-radius: 20rpx;
  background: #fffdf8;
  box-shadow: 0 10rpx 26rpx rgba(70, 88, 51, 0.06);
}

.section-heading,
.update-head,
.faq-head,
.date-row,
.detail-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.section-title {
  color: #273323;
  font-size: 31rpx;
  font-weight: 800;
}

.section-subtitle {
  margin-top: 8rpx;
  color: #7a826f;
  font-size: 22rpx;
  line-height: 1.5;
}

.progress-line {
  display: grid;
  grid-template-columns: repeat(6, minmax(0, 1fr));
  margin-top: 30rpx;
}

.progress-step {
  position: relative;
  text-align: center;
}

.progress-step::before {
  position: absolute;
  top: 10rpx;
  left: -50%;
  width: 100%;
  height: 3rpx;
  background: #dfe5da;
  content: '';
}

.progress-step:first-child::before {
  display: none;
}

.step-dot {
  position: relative;
  z-index: 2;
  width: 20rpx;
  height: 20rpx;
  margin: 0 auto;
  border: 4rpx solid #d7dfd1;
  border-radius: 50%;
  background: #fff;
}

.step-done .step-dot,
.step-active .step-dot {
  border-color: #4f7d46;
  background: #4f7d46;
}

.step-done::before,
.step-active::before {
  background: #80a972;
}

.step-label {
  margin-top: 12rpx;
  color: #7a826f;
  font-size: 20rpx;
}

.step-active .step-label {
  color: #2f6d39;
  font-weight: 700;
}

.date-summary,
.reservation-details {
  margin-top: 28rpx;
  padding: 8rpx 20rpx;
  border-radius: 14rpx;
  background: #f3f7ef;
}

.date-row,
.detail-row {
  min-height: 70rpx;
  border-bottom: 1rpx solid rgba(73, 101, 56, 0.08);
  color: #5f6858;
  font-size: 23rpx;
}

.date-row:last-child,
.detail-row:last-child {
  border-bottom: 0;
}

.date-row text:last-child,
.detail-row text:last-child {
  color: #2f5f35;
  font-weight: 700;
  text-align: right;
}

.situation-note {
  margin-top: 18rpx;
  color: #737b6d;
  font-size: 23rpx;
  line-height: 1.6;
}

.variety-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 22rpx;
}

.variety-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 78rpx;
  padding: 0 22rpx;
  border: 1rpx solid #dde3d8;
  border-radius: 14rpx;
  color: #5f6858;
  background: #fff;
  font-size: 25rpx;
  box-sizing: border-box;
}

.variety-option.active {
  border-color: #5d8b51;
  color: #285d32;
  background: #edf6e8;
  font-weight: 700;
}

.option-check {
  color: #3e7b42;
}

.notification-text {
  margin-top: 10rpx;
  font-size: 23rpx;
}

.tone-success {
  color: #2f7d42;
}

.tone-warning {
  color: #a06d28;
}

.tone-muted {
  color: #8b9185;
}

button::after {
  border: 0;
}

.primary-action {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  margin-top: 24rpx;
  border: 0;
  border-radius: 14rpx;
  color: #fffdf7;
  background: #3f783f;
  font-size: 28rpx;
  font-weight: 800;
}

.primary-action[disabled] {
  color: #7c8677;
  background: #dfe5da;
}

.secondary-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 14rpx;
}

.secondary-actions button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 74rpx;
  border: 1rpx solid #cbdac4;
  border-radius: 14rpx;
  color: #315e35;
  background: #fff;
  font-size: 24rpx;
}

.secondary-actions .cancel-action {
  color: #9b5d56;
  border-color: #ead4cf;
}

.empty-state {
  margin-top: 22rpx;
  padding: 34rpx 20rpx;
  border-radius: 14rpx;
  color: #92988d;
  background: #f7f8f4;
  font-size: 23rpx;
  text-align: center;
}

.update-list {
  margin-top: 20rpx;
}

.update-item {
  display: flex;
  gap: 18rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(73, 101, 56, 0.08);
}

.update-item:last-child {
  border-bottom: 0;
}

.update-image {
  flex: 0 0 auto;
  width: 142rpx;
  height: 112rpx;
  border-radius: 12rpx;
}

.update-copy {
  flex: 1;
  min-width: 0;
}

.update-title {
  color: #273323;
  font-size: 26rpx;
  font-weight: 700;
}

.update-stage {
  min-height: 34rpx;
  padding: 0 10rpx;
  font-size: 18rpx;
}

.update-date,
.update-summary {
  margin-top: 7rpx;
  color: #7a826f;
  font-size: 21rpx;
  line-height: 1.45;
}

.faq-section {
  padding-bottom: 12rpx;
}

.faq-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(73, 101, 56, 0.09);
}

.faq-head {
  color: #394334;
  font-size: 25rpx;
  font-weight: 700;
}

.faq-content {
  margin-top: 14rpx;
  color: #737b6d;
  font-size: 23rpx;
  line-height: 1.65;
}
