page {
  background: #f7f3e9;
  color: #25331e;
}

.guide-page {
  min-height: 100vh;
  padding: 22rpx 22rpx calc(42rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  overflow-x: hidden;
}

.hero-card {
  position: relative;
  min-height: 430rpx;
  overflow: hidden;
  border-radius: 32rpx;
  background: #eaf4dd;
  box-shadow: 0 16rpx 42rpx rgba(72, 95, 55, 0.14);
}

.hero-image,
.hero-mask {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.hero-mask {
  background: linear-gradient(90deg, rgba(247, 252, 238, 0.98) 0%, rgba(247, 252, 238, 0.78) 46%, rgba(247, 252, 238, 0.14) 78%);
}

.hero-copy {
  position: relative;
  z-index: 2;
  max-width: 500rpx;
  padding: 72rpx 34rpx 34rpx;
  box-sizing: border-box;
}

.hero-kicker {
  display: inline-flex;
  padding: 9rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 253, 247, 0.88);
  color: #3f6538;
  font-size: 22rpx;
  font-weight: 700;
}

.hero-title {
  margin-top: 22rpx;
  color: #123f1d;
  font-size: 52rpx;
  font-weight: 800;
  line-height: 1.12;
}

.hero-subtitle {
  margin-top: 18rpx;
  color: #24492a;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.4;
}

.hero-note {
  margin-top: 14rpx;
  color: #65715f;
  font-size: 24rpx;
  line-height: 1.55;
}

.section-card {
  margin-top: 24rpx;
  padding: 26rpx;
  border-radius: 28rpx;
  background: rgba(255, 253, 248, 0.98);
  box-shadow: 0 12rpx 34rpx rgba(82, 106, 56, 0.08);
  box-sizing: border-box;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.section-title {
  color: #172416;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.3;
}

.section-desc {
  margin-top: 10rpx;
  color: #66705f;
  font-size: 24rpx;
  line-height: 1.55;
}

.variety-card {
  display: flex;
  gap: 22rpx;
  margin-top: 24rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(79, 125, 70, 0.12);
  border-radius: 24rpx;
  background: linear-gradient(90deg, #f5fbef 0%, #fffdf8 100%);
  box-sizing: border-box;
}

.press-card {
  opacity: 0.9;
  transform: scale(0.99);
}

.variety-image {
  flex: 0 0 auto;
  width: 180rpx;
  height: 180rpx;
  border-radius: 20rpx;
  background: #edf3e5;
}

.variety-copy {
  flex: 1;
  min-width: 0;
}

.variety-name {
  color: #1c2c19;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.25;
}

.info-row {
  margin-top: 14rpx;
}

.info-label {
  color: #3f6538;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1.3;
}

.info-text {
  margin-top: 5rpx;
  color: #566250;
  font-size: 23rpx;
  line-height: 1.5;
}

.variety-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.light-button,
.reminder-button,
.bottom-primary,
.bottom-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-width: 0;
  margin: 0;
  padding: 0 14rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  font-weight: 700;
  line-height: 1.2;
  white-space: nowrap;
}

.light-button::after,
.reminder-button::after,
.bottom-primary::after,
.bottom-secondary::after {
  border: 0;
}

.light-button {
  height: 62rpx;
  border: 1rpx solid #cbdcc4;
  background: #ffffff;
  color: #47723f;
  font-size: 22rpx;
}

.primary-lite {
  background: #edf7e8;
  color: #2f7638;
}

.time-card {
  background: #eef6e8;
  box-shadow: none;
}

.time-list {
  margin-top: 18rpx;
}

.time-item {
  position: relative;
  padding: 0 0 16rpx 26rpx;
  color: #4f5c49;
  font-size: 24rpx;
  line-height: 1.6;
}

.time-item::before {
  content: "";
  position: absolute;
  left: 0;
  top: 14rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #4f7d46;
}

.reminder-strip {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 8rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background: #fffdf8;
}

.reminder-strip > view {
  flex: 1;
  min-width: 0;
}

.reminder-title {
  color: #223b20;
  font-size: 27rpx;
  font-weight: 800;
}

.reminder-desc {
  margin-top: 8rpx;
  color: #66705f;
  font-size: 22rpx;
  line-height: 1.45;
}

.reminder-button {
  flex: 0 0 190rpx;
  height: 68rpx;
  background: #4f7d46;
  color: #ffffff;
  font-size: 24rpx;
}

.delivery-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 22rpx;
}

.delivery-card {
  min-width: 0;
  min-height: 188rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(79, 125, 70, 0.12);
  border-radius: 22rpx;
  background: #fffdf8;
  box-sizing: border-box;
}

.delivery-title {
  color: #172416;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.3;
}

.delivery-desc {
  margin-top: 10rpx;
  color: #66705f;
  font-size: 22rpx;
  line-height: 1.45;
}

.delivery-link {
  margin-top: 14rpx;
  color: #2f7638;
  font-size: 22rpx;
  font-weight: 700;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 22rpx;
}

.photo-item {
  width: 100%;
  height: 156rpx;
  border-radius: 16rpx;
  background: #edf3e5;
}

.photo-press {
  opacity: 0.86;
  transform: scale(0.985);
}

.photo-tip {
  margin-top: 18rpx;
  color: #5e6a58;
  font-size: 23rpx;
  line-height: 1.45;
}

.bottom-actions {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 16rpx;
  margin-top: 24rpx;
}

.bottom-primary,
.bottom-secondary {
  height: 82rpx;
  font-size: 27rpx;
}

.bottom-primary {
  background: #4f7d46;
  color: #ffffff;
}

.bottom-secondary {
  border: 1rpx solid #cbdcc4;
  background: #fffdf8;
  color: #47723f;
}
