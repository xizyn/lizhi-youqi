.my-page {
  padding: 48rpx 30rpx 72rpx;
  background: #f8f3e9;
}

.my-head {
  padding: 30rpx 0 26rpx;
}

.my-title {
  color: #273323;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.25;
}

.my-subtitle {
  margin-top: 14rpx;
  color: #75806d;
  font-size: 25rpx;
  line-height: 1.6;
}

.summary-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 20rpx;
}

.summary-item {
  padding: 26rpx 10rpx;
  border: 1rpx solid rgba(82, 111, 65, 0.12);
  border-radius: 18rpx;
  background: #fffdf7;
  text-align: center;
}

.summary-num {
  color: #8d3d38;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.2;
}

.summary-label {
  margin-top: 8rpx;
  color: #6b765f;
  font-size: 22rpx;
}

.my-list {
  margin-top: 44rpx;
  border-top: 1rpx solid rgba(72, 93, 58, 0.09);
}

.my-link {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 28rpx 0;
  border-bottom: 1rpx solid rgba(72, 93, 58, 0.09);
}

.link-title {
  color: #293624;
  font-size: 29rpx;
  font-weight: 600;
  line-height: 1.4;
}

.link-desc {
  margin-top: 6rpx;
  color: #7a8270;
  font-size: 23rpx;
  line-height: 1.5;
}

.link-arrow {
  color: #9aa391;
  font-size: 42rpx;
  line-height: 1;
}

.contact-button {
  width: 100%;
  height: 82rpx;
  margin-top: 44rpx;
  border: 0;
  border-radius: 999rpx;
  color: #fffdf7;
  background: #4f7d46;
  font-size: 27rpx;
  font-weight: 600;
  line-height: 82rpx;
}

.contact-button::after {
  border: 0;
}
