      <view class="admin-workbench-title">积分系统运行正常</view>
      <view class="admin-workbench-desc">当前为本机演示账户，关键调整均保留原因和时间记录。</view>
      <view class="admin-kpi-grid history-kpi-grid">
        <view class="admin-kpi-card tone-{{item.tone}}" wx:for="{{pointWorkbench.overview}}" wx:key="key">
          <view class="admin-kpi-value">{{item.value}}</view>
          <view class="admin-kpi-label">{{item.label}}</view>
        </view>
      </view>
    </view>

    <view class="admin-business-section">
      <view class="admin-section-title">常用操作</view>
      <view class="admin-action-grid">
        <view class="admin-action-card" data-panel="adjust" bindtap="openPointPanel">
          <view class="admin-action-title">手动增减积分</view>
          <view class="admin-action-desc">奖励反馈或人工修正</view>
        </view>
        <view class="admin-action-card" data-panel="rules" bindtap="openPointPanel">
          <view class="admin-action-title">查看积分规则</view>
          <view class="admin-action-desc">抵扣比例与有效期</view>
        </view>
        <view class="admin-action-card" data-panel="records" bindtap="openPointPanel">
          <view class="admin-action-title">积分流水</view>
          <view class="admin-action-desc">查看最近发放与扣减</view>
        </view>
        <view class="admin-action-card" bindtap="showPointUserInfo">
          <view class="admin-action-title">用户积分查询</view>
          <view class="admin-action-desc">正式版按 OpenID 查询</view>
        </view>
      </view>
    </view>

    <view class="admin-business-section" wx:if="{{pointEditPanel == 'adjust'}}">
      <view class="admin-section-title">手动调整积分</view>
      <view class="admin-section-desc">必须填写调整原因，避免无记录修改</view>
      <view class="grid-fields">
        <view class="field">
          <view class="field-label">调整类型</view>
          <picker mode="selector" range="{{pointChangeTypes}}" value="{{pointChangeTypeIndex}}" bindchange="handlePointTypeChange">
            <view class="picker-value">{{pointForm.changeType}}</view>
          </picker>
        </view>
        <view class="field">
          <view class="field-label">积分数量</view>
          <input class="field-input" type="number" value="{{pointForm.points}}" data-field="points" bindinput="handlePointInput" placeholder="例如 20" />
        </view>
      </view>
      <view class="field">
        <view class="field-label">调整原因</view>
        <textarea class="field-textarea small-textarea" maxlength="160" value="{{pointForm.reason}}" data-field="reason" bindinput="handlePointInput" placeholder="例如 有效评价/反馈奖励20积分" />
      </view>
      <button class="action-btn green-btn" bindtap="submitPointAdjustment">保存积分调整</button>
    </view>

    <view class="admin-business-section" wx:if="{{pointEditPanel == 'rules'}}">
      <view class="admin-section-title">积分规则</view>
      <view class="admin-section-desc">规则只做展示，本次不改计算逻辑</view>
      <view class="rule-line" wx:for="{{pointSummary.rules}}" wx:key="*this">{{item}}</view>
    </view>

    <view class="admin-business-section" wx:if="{{pointEditPanel == 'records'}}">
      <view class="admin-section-head">
        <view>
          <view class="admin-section-title">最近积分流水</view>
          <view class="admin-section-desc">按时间倒序显示本机记录</view>
        </view>
      </view>
      <view class="admin-empty-state" wx:if="{{pointSummary.records.length == 0}}">暂无积分变动记录</view>
      <view class="record-card point-record-card" wx:for="{{pointSummary.records}}" wx:key="id">
        <view class="record-top">
          <view>
            <view class="record-name">{{item.title}}</view>
            <view class="record-time">{{item.time}}</view>
          </view>
          <view class="point-change {{item.points > 0 ? 'plus' : 'minus'}}">{{item.valueText}}</view>
        </view>
        <view class="record-line">原因：{{item.reason}}</view>
        <view class="record-line">有效期：{{item.expireText}}</view>
        <view class="record-line" wx:if="{{item.orderNo}}">关联订单：{{item.orderNo}}</view>
      </view>
    </view>

    <view class="admin-business-section point-rule-overview">
      <view class="admin-section-head">
        <view>
          <view class="admin-section-title">当前规则摘要</view>
          <view class="admin-section-desc">100 积分 = 1 元，每单最多抵扣商品金额的 5%</view>
        </view>
        <view class="admin-section-count">12个月</view>
      </view>
    </view>
  </block>

  <block wx:elif="{{activeTab == 'products'}}">
    <view class="product-workbench">
      <view class="product-workbench-head">
        <view>
          <view class="product-workbench-title">商品工作台</view>
          <view class="product-workbench-subtitle">先处理异常，再维护商品价格与销售状态</view>
        </view>
        <button class="product-refresh-btn" bindtap="refreshProductWorkbench">刷新</button>
      </view>
      <view class="product-admin-note">仅管理员可编辑商品、价格与库存状态</view>
      <view class="product-stat-grid">
        <view class="product-stat-card tone-{{item.tone}}" wx:for="{{productStats}}" wx:key="key">
          <view class="product-stat-value">{{item.value}}</view>
          <view class="product-stat-label">{{item.label}}</view>
        </view>
      </view>
    </view>

    <view class="product-section" wx:if="{{productIssues.length}}">
      <view class="product-section-head">
        <view>
          <view class="product-section-title">待处理事项</view>
          <view class="product-section-desc">优先处理会影响正常销售的问题</view>
        </view>
        <view class="product-issue-total">{{productIssues.length}} 项</view>
      </view>
      <view
        class="product-issue-row"
        wx:for="{{productIssues}}"
        wx:key="key"
        data-panel="{{item.panel}}"
        bindtap="openProductPanel"
      >
        <view class="product-issue-count">{{item.count}}</view>
        <view class="product-issue-copy">
          <view class="product-issue-title">{{item.title}}</view>
          <view class="product-issue-desc">{{item.desc}}</view>
        </view>
        <view class="product-row-arrow">›</view>
      </view>
    </view>

    <view class="product-section product-healthy" wx:else>
      <view class="product-healthy-title">当前商品状态正常</view>
      <view class="product-section-desc">已上架商品均已设置价格，暂无售罄待补事项。</view>
    </view>

    <view class="product-section" id="product-preview-panel">
      <view class="product-section-head">
        <view>
          <view class="product-section-title">商品预览</view>
          <view class="product-section-desc">快速查看用户端商品价格与销售状态</view>
        </view>
        <view class="product-link" bindtap="toggleProductPreview">{{productPreviewExpanded ? '收起' : '查看全部'}}</view>
      </view>
      <view class="product-preview-list">
        <block wx:for="{{productPreviewRows}}" wx:key="id">
          <view class="product-preview-row" wx:if="{{productPreviewExpanded || index < 3}}">
            <image class="product-preview-image" src="{{item.image}}" mode="aspectFill"></image>
            <view class="product-preview-copy">
              <view class="product-preview-name">{{item.name}}</view>
              <view class="product-preview-meta">{{item.variety}} · {{item.spec}}</view>
            </view>
            <view class="product-preview-side">
              <view class="product-preview-price {{item.hasPrice ? '' : 'missing'}}">{{item.priceText}}</view>
              <view class="product-status-tag status-{{item.statusTone}}">{{item.statusText}}</view>
            </view>
          </view>
        </block>
      </view>
    </view>

    <view class="product-section">
      <view class="product-section-head">
        <view>
          <view class="product-section-title">快捷管理</view>
          <view class="product-section-desc">进入对应区域完成配置</view>
        </view>
      </view>
      <view class="product-tool-grid">
        <view class="product-tool-card" data-panel="preview" bindtap="openProductPanel">
          <view class="product-tool-title">商品管理</view>
          <view class="product-tool-desc">查看全部商品</view>
        </view>
        <view class="product-tool-card" data-panel="status" bindtap="openProductPanel">
          <view class="product-tool-title">库存状态</view>
          <view class="product-tool-desc">上架与售罄控制</view>
        </view>
        <view class="product-tool-card" data-panel="price" bindtap="openProductPanel">
          <view class="product-tool-title">价格规格</view>
          <view class="product-tool-desc">维护当前售价</view>
        </view>
        <view class="product-tool-card" bindtap="showProductCategoryInfo">
          <view class="product-tool-title">分类概览</view>
          <view class="product-tool-desc">固定 {{productCategoryCount}} 类 SKU</view>
        </view>
      </view>
    </view>

    <view class="product-section" id="product-price-panel">
      <view class="product-section-head">
        <view>
          <view class="product-section-title">价格与规格</view>
          <view class="product-section-desc">价格调整后保存，用户端读取同一份本地配置</view>
        </view>
      </view>
      <view class="grid-fields">
        <view class="field" wx:for="{{priceRows}}" wx:key="key">
          <view class="field-label">{{item.label}}</view>
          <input class="field-input" type="digit" value="{{item.value}}" data-index="{{index}}" bindinput="handlePriceInput" placeholder="0" />
        </view>
      </view>
    </view>

    <view class="product-section" id="product-variety-stock-panel">
      <view class="product-section-head">
        <view>
          <view class="product-section-title">品种库存重量</view>
          <view class="product-section-desc">按实际可售鲜果重量记录，5斤装、10斤装和混装都从对应品种库存中安排。</view>
        </view>
      </view>
      <view class="variety-stock-list">
        <view class="variety-stock-row" wx:for="{{varietyStockRows}}" wx:key="key">
          <text class="variety-stock-label">{{item.label}}</text>
          <view class="variety-stock-input-wrap">
            <input class="variety-stock-input" type="digit" value="{{item.value}}" data-index="{{index}}" bindinput="handleVarietyStockInput" placeholder="未设置" />
            <text class="variety-stock-unit">斤</text>
          </view>
        </view>
      </view>
    </view>

    <view class="product-section" id="product-status-panel">
      <view class="product-section-head">
        <view>
          <view class="product-section-title">库存与销售状态</view>
          <view class="product-section-desc">上架 / 售罄开关用于控制各 SKU 的展示和销售状态。</view>
        </view>
      </view>
      <view class="sku-status-list">
        <view class="sku-status-card" wx:for="{{skuStatusRows}}" wx:key="id">
          <image class="sku-status-image" src="{{item.image}}" mode="aspectFill"></image>
          <view class="sku-status-copy">
            <view class="record-name">{{item.name}}</view>
            <view class="record-time">{{item.spec}} · {{item.priceText}}</view>
          </view>
          <view class="sku-switches">
            <view class="switch-line">
              <text>上架</text>
              <switch checked="{{item.isListed}}" data-index="{{index}}" data-field="isListed" bindchange="handleSkuStatusSwitch" />
            </view>
            <view class="switch-line">
              <text>售罄</text>
              <switch checked="{{item.isSoldOut}}" data-index="{{index}}" data-field="isSoldOut" bindchange="handleSkuStatusSwitch" />
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="product-section">
      <view class="product-section-head">
        <view>
          <view class="product-section-title">销售总状态</view>
          <view class="product-section-desc">控制首页和下单页显示的当前销售阶段</view>
        </view>
      </view>
      <picker mode="selector" range="{{salesStatusLabels}}" value="{{salesStatusIndex}}" bindchange="handleStatusChange">
        <view class="picker-value">{{salesStatusLabels[salesStatusIndex]}}</view>
      </picker>
    </view>

    <view class="product-section">
      <view class="product-section-head product-collapsible-head" bindtap="toggleProductAdvanced">
        <view>
          <view class="product-section-title">其他后台配置</view>
          <view class="product-section-desc">权限、公告和自提信息等低频设置</view>
        </view>
        <view class="product-collapse-arrow">{{productAdvancedExpanded ? '收起' : '展开'}}</view>
      </view>
      <view wx:if="{{productAdvancedExpanded}}">
      <view class="field">
        <view class="field-label">后台密码</view>
        <input class="field-input" value="{{configForm.adminPassword}}" data-field="adminPassword" bindinput="handleTopInput" placeholder="开发阶段模拟密码" />
      </view>
      <view class="field">
        <view class="field-label">开发模式管理员入口</view>
        <input class="field-input" value="{{configForm.isAdminMock}}" data-field="isAdminMock" bindinput="handleTopInput" placeholder="true 才显示我的页后台入口" />
      </view>
      <view class="field">
        <view class="field-label">当前 mock openid</view>
        <input class="field-input" value="{{configForm.mockOpenid}}" data-field="mockOpenid" bindinput="handleTopInput" placeholder="开发阶段模拟用户 openid" />
      </view>
      <view class="field">
        <view class="field-label">管理员 openid 白名单</view>
        <textarea class="field-textarea small-textarea" maxlength="240" value="{{configForm.adminOpenidWhitelist}}" data-field="adminOpenidWhitelist" bindinput="handleTopInput" placeholder="一行一个 openid，正式上线改为服务端校验" />
      </view>
      <view class="field">
        <view class="field-label">后台公告</view>
        <textarea class="field-textarea" maxlength="240" value="{{configForm.announcement}}" data-field="announcement" bindinput="handleTopInput" />
      </view>
      <view class="field">
        <view class="field-label">当前采摘状态</view>
        <input class="field-input" value="{{configForm.harvestStatus}}" data-field="harvestStatus" bindinput="handleTopInput" />
      </view>
      <view class="field">
        <view class="field-label">自提地址</view>
        <textarea class="field-textarea small-textarea" maxlength="160" value="{{configForm.pickupAddress}}" data-field="pickupAddress" bindinput="handleTopInput" />
      </view>
      <view class="field">
        <view class="field-label">自提时间</view>
        <input class="field-input" value="{{configForm.pickupTime}}" data-field="pickupTime" bindinput="handleTopInput" />
      </view>
      <view class="field">
        <view class="field-label">高德地图截图路径</view>
        <input class="field-input" value="{{configForm.pickupMapImage}}" data-field="pickupMapImage" bindinput="handleTopInput" placeholder="/assets/images/pickup-map.png" />
      </view>
      </view>
    </view>

    <view class="product-section">
      <view class="product-section-head">
        <view>
          <view class="product-section-title">最近操作</view>
          <view class="product-section-desc">本机记录最近 5 次商品配置保存</view>
        </view>
      </view>
      <view class="product-log-empty" wx:if="{{productOperationLogs.length == 0}}">保存商品设置后，将在这里显示操作记录。</view>
      <view class="product-log-row" wx:for="{{productOperationLogs}}" wx:key="id">
        <view class="product-log-dot"></view>
        <view class="product-log-copy">
          <view class="product-log-text">{{item.text}}</view>
          <view class="product-log-time">{{item.time}}</view>
        </view>
      </view>
    </view>

    <view class="button-stack">
      <button class="action-btn green-btn product-save-btn" bindtap="saveConfigOnly">保存商品设置</button>
    </view>
  </block>

  <block wx:elif="{{activeTab == 'delivery'}}">
    <view class="admin-workbench-hero delivery-hero">
      <view class="admin-workbench-eyebrow">配送规则中心</view>
      <view class="admin-workbench-title">{{deliveryWorkbench.enabledCount}} 种配送方式已启用</view>
      <view class="admin-workbench-desc" wx:if="{{deliveryWorkbench.incompleteCount > 0}}">还有 {{deliveryWorkbench.incompleteCount}} 项基础信息需要补充。</view>
      <view class="admin-workbench-desc" wx:else>自提、附近送和顺丰快递配置完整。</view>
    </view>

    <view class="admin-business-section">
      <view class="admin-section-head">
        <view>
          <view class="admin-section-title">配送方式</view>
          <view class="admin-section-desc">展开卡片即可修改对应规则</view>
        </view>
      </view>
      <view class="delivery-method-card" wx:for="{{deliveryWorkbench.methods}}" wx:key="key">
        <view class="delivery-method-head">
          <view>
            <view class="delivery-method-title">{{item.title}}</view>
            <view class="delivery-method-status">{{item.status}}</view>
          </view>
          <button class="delivery-edit-btn" data-panel="{{item.key}}" bindtap="openDeliveryPanel">{{deliveryEditPanel == item.key ? '收起' : '编辑'}}</button>
        </view>
        <view class="delivery-method-line">{{item.line1}}</view>
        <view class="delivery-method-line muted">{{item.line2}}</view>
      </view>
    </view>

    <view class="admin-business-section" wx:if="{{deliveryEditPanel == 'pickup'}}">
      <view class="section-title">自提时段</view>
      <view class="field">
        <view class="field-label">自提地址</view>
        <input class="field-input" value="{{configForm.pickupAddress}}" data-field="pickupAddress" bindinput="handleTopInput" />
      </view>
      <view class="field">
        <view class="field-label">自提说明</view>
        <input class="field-input" value="{{configForm.pickupTime}}" data-field="pickupTime" bindinput="handleTopInput" />
      </view>
      <view class="slot-row" wx:for="{{pickupTimeSlotRows}}" wx:key="value">
        <input class="field-input slot-input" value="{{item.value}}" data-index="{{index}}" bindinput="handlePickupSlotInput" placeholder="例如 9:00-11:00" />
        <button class="mini-btn plain-btn slot-remove" data-index="{{index}}" bindtap="removePickupSlot">删除</button>
      </view>
      <button class="mini-btn plain-btn" bindtap="addPickupSlot">新增自提时段</button>
      <button class="action-btn green-btn" bindtap="saveConfigOnly">保存自提设置</button>
    </view>

    <view class="admin-business-section" wx:if="{{deliveryEditPanel == 'nearby'}}">
      <view class="section-title">附近送设置</view>
      <view class="field">
        <view class="field-label">支持区域</view>
        <textarea class="field-textarea small-textarea" value="{{nearbyAreasText}}" bindinput="handleNearbyAreasInput" placeholder="多个区域用顿号或逗号分隔" />
      </view>
      <view class="field">
        <view class="field-label">配送费</view>
        <input class="field-input" type="digit" value="{{configForm.nearbyDelivery.deliveryFee}}" data-field="nearbyDelivery.deliveryFee" bindinput="handleDeliveryConfigInput" />
      </view>
      <view class="field">
        <view class="field-label">配送范围说明</view>
        <textarea class="field-textarea small-textarea" value="{{configForm.nearbyDelivery.scopeNote}}" data-field="nearbyDelivery.scopeNote" bindinput="handleDeliveryConfigInput" />
      </view>
      <button class="action-btn green-btn" bindtap="saveConfigOnly">保存附近送设置</button>
    </view>

    <view class="admin-business-section" wx:if="{{deliveryEditPanel == 'express'}}">
      <view class="section-title">顺丰快递设置</view>
      <view class="section-subtitle">5斤装按4kg预估，10斤装按6kg预估，实际以顺丰结算为准。</view>
      <view class="grid-fields">
        <view class="field" wx:for="{{shippingFeeRows}}" wx:key="key">
          <view class="field-label">{{item.label}}</view>
          <input class="field-input" type="digit" value="{{item.value}}" data-index="{{index}}" bindinput="handleShippingFeeInput" placeholder="0" />
        </view>
      </view>
      <view class="field">
        <view class="field-label">冷运说明</view>
        <textarea class="field-textarea small-textarea" value="{{configForm.expressDelivery.coldChainSummary}}" data-field="expressDelivery.coldChainSummary" bindinput="handleDeliveryConfigInput" />
      </view>
      <view class="field">
        <view class="field-label">时效说明</view>
        <textarea class="field-textarea small-textarea" value="{{configForm.expressDelivery.transitNotice}}" data-field="expressDelivery.transitNotice" bindinput="handleDeliveryConfigInput" />
      </view>
      <button class="action-btn green-btn" bindtap="saveConfigOnly">保存快递设置</button>
    </view>

    <view class="admin-business-section delivery-log-entry">
      <view class="admin-section-head">
        <view>
          <view class="admin-section-title">操作记录</view>
          <view class="admin-section-desc">配送规则保存后记录在本机配置中</view>
        </view>
        <view class="admin-section-count">查看说明</view>
      </view>
    </view>
  </block>
</view>
