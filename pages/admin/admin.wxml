        <view class="orchard-update-copy">
          <view class="record-name">{{reminderWorkbench.latestUpdate.title}}</view>
          <view class="record-time">{{reminderWorkbench.latestUpdate.date}} · {{reminderWorkbench.latestUpdate.stage}}</view>
          <view class="record-line">{{reminderWorkbench.latestUpdate.summary}}</view>
        </view>
