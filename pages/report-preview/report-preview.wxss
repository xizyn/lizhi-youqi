.preview-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 56rpx;
  color: #263321;
  background: #f8f3e9;
}

.preview-head-card {
  padding: 30rpx 28rpx;
  border: 1rpx solid rgba(63, 115, 53, 0.12);
  border-radius: 20rpx;
  background: linear-gradient(135deg, #edf6e7 0%, #fffdf8 100%);
  box-shadow: 0 10rpx 28rpx rgba(67, 91, 48, 0.07);
}

.preview-kicker {
  display: inline-flex;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  color: #2f7d42;
  background: #e1f0d9;
  font-size: 21rpx;
  font-weight: 700;
}

.preview-title {
  margin-top: 18rpx;
  color: #1f3a22;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.2;
}

.preview-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx 28rpx;
  margin-top: 14rpx;
  color: #6e7867;
  font-size: 22rpx;
}

.section-heading,
.panel-heading {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
}

.section-heading {
  margin: 30rpx 4rpx 16rpx;
}

.section-title,
.panel-title {
  color: #25331e;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.3;
}

.section-note,
.panel-note {
  margin-top: 5rpx;
  color: #858c7d;
  font-size: 21rpx;
  line-height: 1.45;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.summary-card {
  min-width: 0;
  min-height: 126rpx;
  padding: 20rpx 10rpx;
  border: 1rpx solid rgba(63, 115, 53, 0.08);
  border-radius: 16rpx;
  background: #fffdf8;
  box-shadow: 0 7rpx 20rpx rgba(67, 91, 48, 0.05);
  text-align: center;
}

.summary-value {
  overflow: hidden;
  color: #2f7d42;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.summary-label {
  margin-top: 10rpx;
  color: #697362;
  font-size: 20rpx;
  line-height: 1.35;
}

.tone-red .summary-value,
.tone-red .overview-value {
  color: #ae493f;
}

.tone-blue .summary-value,
.tone-blue .overview-value {
  color: #3974a7;
}

.tone-orange .summary-value,
.tone-orange .overview-value {
  color: #ad721f;
}

.report-tabs {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 8rpx;
  margin-top: 28rpx;
  padding: 8rpx;
  border: 1rpx solid rgba(63, 115, 53, 0.1);
  border-radius: 16rpx;
  background: #fffdf8;
  box-shadow: 0 7rpx 20rpx rgba(67, 91, 48, 0.05);
}

.report-tab {
  min-width: 0;
  height: 66rpx;
  border-radius: 12rpx;
  color: #626c5b;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 66rpx;
  text-align: center;
}

.report-tab.active {
  color: #fff;
  background: #3f7d3c;
}

.tab-panel {
  margin-top: 24rpx;
}

.panel-heading {
  margin: 0 4rpx 16rpx;
}

.overview-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.overview-card {
  min-width: 0;
  padding: 22rpx 20rpx;
  border: 1rpx solid rgba(63, 115, 53, 0.08);
  border-radius: 16rpx;
  background: #fffdf8;
  box-shadow: 0 7rpx 20rpx rgba(67, 91, 48, 0.05);
}

.overview-label {
  color: #727a6c;
  font-size: 21rpx;
  line-height: 1.35;
}

.overview-value {
  margin-top: 8rpx;
  color: #2f7d42;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.25;
}

.finance-card {
  margin-top: 18rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(63, 115, 53, 0.09);
  border-radius: 16rpx;
  background: #fffdf8;
  box-shadow: 0 7rpx 20rpx rgba(67, 91, 48, 0.05);
}

.finance-title {
  color: #30412b;
  font-size: 26rpx;
  font-weight: 800;
}

.finance-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx 12rpx;
  margin-top: 18rpx;
}

.finance-item {
  min-width: 0;
  padding: 16rpx;
  border-radius: 12rpx;
  background: #f4f8ef;
}

.finance-value {
  color: #2f7d42;
  font-size: 29rpx;
  font-weight: 800;
}

.finance-value.warning {
  color: #a96e1c;
}

.finance-value.danger {
  color: #a94b43;
}

.finance-label {
  margin-top: 6rpx;
  color: #747c6e;
  font-size: 20rpx;
}

.harvest-main-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.harvest-main-card {
  min-width: 0;
  padding: 26rpx 8rpx;
  border: 1rpx solid rgba(63, 115, 53, 0.1);
  border-radius: 16rpx;
  background: #eef6e7;
  text-align: center;
}

.harvest-main-card.total {
  background: #fff3e9;
}

.harvest-number {
  color: #2f7d42;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.25;
}

.harvest-main-card.total .harvest-number {
  color: #a84f42;
}

.harvest-label {
  margin-top: 8rpx;
  color: #687260;
  font-size: 20rpx;
}

.gift-summary {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(63, 115, 53, 0.08);
  border-radius: 16rpx;
  background: #fffdf8;
}

.mixed-notice {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border: 1rpx solid #eed9b4;
  border-radius: 12rpx;
  color: #85602e;
  background: #fff8e8;
  font-size: 21rpx;
  line-height: 1.5;
}

.gift-item {
  flex: 1;
  min-width: 0;
  text-align: center;
}

.gift-divider {
  width: 1rpx;
  height: 58rpx;
  background: rgba(63, 115, 53, 0.12);
}

.gift-value {
  color: #ad721f;
  font-size: 32rpx;
  font-weight: 800;
}

.gift-label {
  margin-top: 5rpx;
  color: #737b6c;
  font-size: 20rpx;
}

.subsection-title {
  margin: 28rpx 4rpx 14rpx;
  color: #31402c;
  font-size: 27rpx;
  font-weight: 800;
}

.harvest-group-list,
.delivery-order-list,
.order-detail-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.harvest-group {
  padding: 22rpx;
  border: 1rpx solid rgba(63, 115, 53, 0.1);
  border-left-width: 7rpx;
  border-radius: 16rpx;
  background: #fffdf8;
  box-shadow: 0 7rpx 20rpx rgba(67, 91, 48, 0.05);
}

.tone-border-blue {
  border-left-color: #4b82b0;
}

.tone-border-green {
  border-left-color: #4a8947;
}

.tone-border-orange {
  border-left-color: #c18131;
}

.group-head,
.delivery-group-head,
.order-card-head,
.product-line,
.order-card-foot {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.group-title,
.delivery-group-title {
  color: #2d3b28;
  font-size: 27rpx;
  font-weight: 800;
}

.group-count,
.delivery-group-desc {
  margin-top: 5rpx;
  color: #858c7d;
  font-size: 20rpx;
}

.group-total {
  flex: 0 0 auto;
  color: #a84f42;
  font-size: 31rpx;
  font-weight: 800;
}

.group-weight-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.group-weight-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  padding: 15rpx;
  border-radius: 12rpx;
  background: #f3f8ef;
}

.weight-label {
  color: #687260;
  font-size: 20rpx;
}

.weight-value {
  color: #2f7d42;
  font-size: 24rpx;
  font-weight: 800;
}

.group-gift {
  margin-top: 14rpx;
  color: #7d7464;
  font-size: 20rpx;
  line-height: 1.45;
}

.group-mixed-note {
  margin-top: 12rpx;
  color: #9b641f;
  font-size: 20rpx;
  font-weight: 700;
}

.delivery-group {
  margin-top: 22rpx;
}

.delivery-group:first-of-type {
  margin-top: 0;
}

.delivery-group-head {
  align-items: center;
  margin: 0 4rpx 12rpx;
}

.delivery-count {
  flex: 0 0 auto;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  color: #386b34;
  background: #e8f3e2;
  font-size: 20rpx;
  font-weight: 700;
}

.tone-bg-blue {
  color: #356c98;
  background: #e8f1f8;
}

.tone-bg-orange {
  color: #9b641f;
  background: #fff0dc;
}

.group-empty,
.empty-table {
  padding: 38rpx 20rpx;
  border: 1rpx dashed rgba(63, 115, 53, 0.2);
  border-radius: 16rpx;
  color: #81897a;
  background: rgba(255, 253, 248, 0.72);
  font-size: 22rpx;
  text-align: center;
}

.order-card {
  padding: 24rpx;
  border: 1rpx solid rgba(63, 115, 53, 0.09);
  border-radius: 16rpx;
  background: #fffdf8;
  box-shadow: 0 8rpx 22rpx rgba(67, 91, 48, 0.06);
}

.order-card.compact {
  padding: 22rpx;
}

.order-no {
  word-break: break-all;
  color: #273623;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1.35;
}

.order-time {
  margin-top: 5rpx;
  color: #8a9084;
  font-size: 19rpx;
}

.status-tag {
  flex: 0 0 auto;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  color: #596055;
  background: #eceeea;
  font-size: 20rpx;
  font-weight: 700;
}

.status-red {
  color: #a7453e;
  background: #fbe9e6;
}

.status-green {
  color: #2f743a;
  background: #e6f3e3;
}

.status-blue {
  color: #356c98;
  background: #e8f1f8;
}

.status-light-green {
  color: #487a42;
  background: #eff7ea;
}

.status-orange {
  color: #9b641f;
  background: #fff0dc;
}

.customer-line {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx 20rpx;
  margin-top: 18rpx;
}

.customer-name {
  color: #31402c;
  font-size: 25rpx;
  font-weight: 800;
}

.customer-phone {
  color: #66705f;
  font-size: 23rpx;
}

.product-line,
.product-block {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 12rpx;
  background: #f3f8ef;
}

.product-detail {
  flex: 1;
  min-width: 0;
  color: #33412e;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.5;
}

.weight-badge {
  flex: 0 0 auto;
  color: #a84f42;
  font-size: 25rpx;
  font-weight: 800;
}

.weight-detail {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx 20rpx;
  margin-top: 12rpx;
  color: #687260;
  font-size: 21rpx;
}

.weight-total {
  color: #a84f42;
  font-weight: 800;
}

.info-line {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-top: 13rpx;
  font-size: 22rpx;
  line-height: 1.5;
}

.info-label {
  flex: 0 0 66rpx;
  color: #899082;
}

.info-value {
  flex: 1;
  min-width: 0;
  color: #4f594a;
  word-break: break-all;
}

.address-line {
  padding-top: 13rpx;
  border-top: 1rpx solid rgba(63, 115, 53, 0.08);
}

.order-card-foot {
  align-items: flex-end;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(63, 115, 53, 0.08);
}

.remark-text {
  flex: 1;
  min-width: 0;
  color: #777f71;
  font-size: 21rpx;
  line-height: 1.45;
  word-break: break-all;
}

.amount-text {
  flex: 0 0 auto;
  color: #a84f42;
  font-size: 30rpx;
  font-weight: 800;
}

.table-toggle {
  width: 100%;
  height: 70rpx;
  margin-top: 18rpx;
  border-radius: 14rpx;
  color: #356b32;
  background: #edf6e7;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 70rpx;
}

.table-toggle::after {
  border: 0;
}

.table-section {
  margin-top: 16rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(63, 115, 53, 0.09);
  border-radius: 16rpx;
  background: #fffdf8;
}

.table-tip {
  margin-bottom: 12rpx;
  color: #858c7d;
  font-size: 20rpx;
}

.table-scroll {
  width: 100%;
  border: 1rpx solid rgba(63, 115, 53, 0.12);
  border-radius: 12rpx;
  background: #fff;
}

.report-table {
  min-width: 100%;
}

.table-row {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: 190rpx;
  min-height: 78rpx;
  border-bottom: 1rpx solid #edf0e9;
}

.table-row:last-child {
  border-bottom: 0;
}

.table-header {
  min-height: 70rpx;
  background: #eef6e7;
}

.table-cell {
  display: flex;
  align-items: center;
  min-width: 0;
  padding: 14rpx 16rpx;
  border-right: 1rpx solid #edf0e9;
  color: #4d5848;
  font-size: 21rpx;
  line-height: 1.45;
  word-break: break-all;
}

.table-cell:last-child {
  border-right: 0;
}

.table-header .table-cell {
  color: #31542d;
  font-weight: 800;
}

.first-cell {
  position: sticky;
  left: 0;
  z-index: 2;
  background: #fff;
}

.table-header .first-cell {
  z-index: 3;
  background: #eef6e7;
}

.report-tools {
  margin-top: 28rpx;
  padding: 22rpx;
  border: 1rpx solid rgba(63, 115, 53, 0.09);
  border-radius: 16rpx;
  background: #fffdf8;
  box-shadow: 0 9rpx 25rpx rgba(67, 91, 48, 0.06);
}

.tool-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.tool-title {
  color: #25331e;
  font-size: 28rpx;
  font-weight: 800;
}

.tool-updated {
  color: #8b9286;
  font-size: 19rpx;
}

.tool-actions {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.tool-btn {
  width: 100%;
  height: 76rpx;
  margin: 0;
  padding: 0 8rpx;
  border-radius: 12rpx;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 76rpx;
}

.tool-btn::after,
.sheet-cancel::after,
.image-action::after {
  border: 0;
}

.refresh-btn {
  color: #315f2e;
  background: #edf6e7;
}

.image-btn {
  color: #fff;
  background: #3f7d3c;
}

.more-btn {
  color: #556051;
  border: 1rpx solid rgba(63, 115, 53, 0.18);
  background: #fff;
}

.tool-tip {
  margin-top: 16rpx;
  color: #858c7d;
  font-size: 20rpx;
  line-height: 1.55;
}

.report-canvas {
  position: fixed;
  top: 0;
  left: -2000rpx;
  width: 702rpx;
  height: 1380rpx;
  opacity: 0;
  pointer-events: none;
}

.sheet-mask,
.image-mask {
  position: fixed;
  z-index: 1000;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  background: rgba(30, 38, 29, 0.38);
}

.sheet-mask {
  align-items: flex-end;
}

.more-sheet {
  width: 100%;
  padding: 28rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  border-radius: 24rpx 24rpx 0 0;
  background: #fffdf8;
}

.sheet-title {
  color: #25331e;
  font-size: 30rpx;
  font-weight: 800;
}

.sheet-note {
  margin-top: 6rpx;
  color: #858c7d;
  font-size: 20rpx;
}

.sheet-action {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 104rpx;
  margin-top: 14rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(63, 115, 53, 0.09);
  border-radius: 14rpx;
  background: #fff;
}

.sheet-action-title {
  color: #30412c;
  font-size: 25rpx;
  font-weight: 700;
}

.sheet-action-desc {
  margin-top: 6rpx;
  color: #858c7d;
  font-size: 19rpx;
}

.sheet-arrow {
  color: #879082;
  font-size: 36rpx;
}

.sheet-cancel {
  width: 100%;
  height: 72rpx;
  margin-top: 18rpx;
  border-radius: 14rpx;
  color: #586255;
  background: #f0f2ed;
  font-size: 23rpx;
  line-height: 72rpx;
}

.image-mask {
  align-items: center;
  justify-content: center;
  padding: 34rpx;
}

.image-result {
  width: 100%;
  max-height: 90vh;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #fffdf8;
  box-shadow: 0 18rpx 50rpx rgba(34, 48, 31, 0.2);
}

.image-result-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.image-result-title {
  color: #25331e;
  font-size: 29rpx;
  font-weight: 800;
}

.image-result-note {
  margin-top: 5rpx;
  color: #858c7d;
  font-size: 19rpx;
}

.image-close {
  color: #778073;
  font-size: 42rpx;
  line-height: 1;
}

.report-image-preview {
  display: block;
  width: 100%;
  height: 680rpx;
  margin-top: 20rpx;
  border: 1rpx solid rgba(63, 115, 53, 0.1);
  border-radius: 14rpx;
  background: #f7f3e9;
}

.image-actions {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.image-action {
  width: 100%;
  height: 70rpx;
  margin: 0;
  padding: 0 6rpx;
  border-radius: 12rpx;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 70rpx;
}

.image-action.secondary {
  color: #315f2e;
  background: #edf6e7;
}

.image-action.primary {
  color: #fff;
  background: #3f7d3c;
}
