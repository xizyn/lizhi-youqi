.member-page {
  padding: 48rpx 30rpx 130rpx;
  background: #faf5eb;
}

.points-card {
  padding: 34rpx 28rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #e9f6e2 0%, #f7fbf2 100%);
  box-shadow: 0 12rpx 28rpx rgba(80, 96, 62, 0.08);
}

.points-label {
  color: #7a826f;
  font-size: 23rpx;
}

.points-value {
  margin-top: 12rpx;
  color: #2f7d42;
  font-size: 68rpx;
  font-weight: 800;
}

.points-note {
  margin-top: 8rpx;
  color: #687060;
  font-size: 23rpx;
  line-height: 1.5;
}

.points-stats {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 24rpx;
}

.points-stats > view {
  padding: 18rpx;
  border-radius: 16rpx;
  background: rgba(255, 253, 247, 0.86);
}

.stat-value {
  color: #2f7d42;
  font-size: 32rpx;
  font-weight: 800;
}

.stat-label {
  margin-top: 6rpx;
  color: #7a826f;
  font-size: 22rpx;
}

.section-card,
.rule-card {
  margin-top: 22rpx;
  padding: 28rpx 24rpx;
  border-radius: 18rpx;
  background: #fffdf7;
  box-shadow: 0 12rpx 28rpx rgba(80, 96, 62, 0.06);
}

.section-title {
  color: #25331e;
  font-size: 30rpx;
  font-weight: 800;
}

.point-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(82, 111, 65, 0.1);
}

.point-row:last-child {
  border-bottom: 0;
}

.point-title {
  color: #303b2a;
  font-size: 26rpx;
  font-weight: 700;
}

.point-meta,
.rule-text,
.rule-item,
.empty {
  margin-top: 8rpx;
  color: #7a826f;
  font-size: 23rpx;
  line-height: 1.55;
}

.point-main { min-width: 0; }

.point-value {
  flex: 0 0 auto;
  font-size: 27rpx;
  font-weight: 800;
}

.point-value.plus {
  color: #2f7d42;
}

.point-value.minus {
  color: #a84d3f;
}

.point-row.expired {
  opacity: 0.55;
}

.rule-item {
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(82, 111, 65, 0.08);
}

.rule-item:last-child {
  border-bottom: 0;
}
