.express-page {
  min-height: 100vh;
  padding: 38rpx 24rpx 72rpx;
  background: #f8f3e9;
  box-sizing: border-box;
}

.page-head {
  padding: 16rpx 4rpx 24rpx;
}

.page-title {
  color: #25331e;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.2;
}

.page-subtitle {
  margin-top: 10rpx;
  color: #5f6f56;
  font-size: 26rpx;
  line-height: 1.55;
}

.notice-box {
  margin-bottom: 26rpx;
  padding: 22rpx 24rpx;
  border: 1rpx solid rgba(79, 125, 70, 0.12);
  border-radius: 18rpx;
  color: #526347;
  background: #eef6e7;
  font-size: 24rpx;
  line-height: 1.7;
}

.notice-title {
  color: #365b35;
  font-size: 25rpx;
  font-weight: 650;
}

.notice-text {
  margin-top: 6rpx;
  color: #66745f;
  font-size: 23rpx;
  line-height: 1.6;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.product-card {
  position: relative;
  overflow: hidden;
  border: 2rpx solid rgba(75, 94, 55, 0.1);
  border-radius: 22rpx;
  background: #fffdf8;
  box-shadow: 0 12rpx 30rpx rgba(57, 74, 44, 0.08);
  transition: border-color 0.16s ease, background 0.16s ease;
}

.product-card.selected {
  border-color: #79a86e;
  background: #f3f8ee;
}

.product-card.disabled {
  opacity: 0.62;
}

.product-card.disabled:active {
  transform: none;
}

.product-image {
  display: block;
  width: 100%;
  height: 190rpx;
  background: #eef6e7;
}

.product-body {
  position: relative;
  padding: 20rpx 18rpx 18rpx;
}

.selected-mark {
  position: absolute;
  top: 14rpx;
  right: 14rpx;
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  color: #ffffff;
  background: #4f7d46;
  font-size: 23rpx;
  line-height: 38rpx;
  text-align: center;
}

.product-name {
  padding-right: 34rpx;
  color: #25331e;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.3;
}

.product-meta {
  margin-top: 8rpx;
  color: #6f7a65;
  font-size: 21rpx;
  line-height: 1.45;
}

.mix-notice {
  margin-top: 10rpx;
  color: #6e785f;
  font-size: 20rpx;
  line-height: 1.45;
}

.shipping-block {
  margin-top: 14rpx;
  padding: 13rpx 12rpx;
  border-radius: 12rpx;
  background: #f0f6e9;
}

.shipping-range {
  color: #41683d;
  font-size: 22rpx;
  font-weight: 600;
}

.shipping-note {
  margin-top: 5rpx;
  color: #7a8374;
  font-size: 18rpx;
  line-height: 1.45;
}

.freight-tag {
  display: inline-flex;
  align-items: center;
  height: 38rpx;
  margin-top: 12rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  color: #4f7d46;
  background: #eef6e7;
  font-size: 20rpx;
  line-height: 38rpx;
}

.sold-tag {
  margin-left: 8rpx;
  color: #8a4a3f;
  background: #fff0ec;
}

.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  margin-top: 18rpx;
}

.product-price {
  color: #b84b43;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.2;
}

.select-pill {
  min-width: 86rpx;
  height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  color: #fffdf8;
  background: #4f7d46;
  font-size: 22rpx;
  line-height: 44rpx;
  text-align: center;
  box-sizing: border-box;
}

.product-card.disabled .select-pill {
  color: #7a8270;
  background: #e7e1d8;
}

.product-card.selected .select-pill {
  color: #3e6d3b;
  background: #dcecd5;
}

.transit-note {
  margin: 24rpx 6rpx 0;
  color: #778071;
  font-size: 21rpx;
  line-height: 1.55;
}

.bottom-placeholder {
  height: 170rpx;
}

.selection-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #e5e7df;
  background: rgba(255, 252, 246, 0.98);
  box-shadow: 0 -8rpx 28rpx rgba(53, 66, 46, 0.08);
}

.selection-summary {
  min-width: 0;
  flex: 1;
}

.selection-label {
  color: #7c8477;
  font-size: 20rpx;
}

.selection-name {
  overflow: hidden;
  margin-top: 3rpx;
  color: #273a29;
  font-size: 25rpx;
  font-weight: 600;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.selection-price {
  margin-top: 3rpx;
  color: #b84b43;
  font-size: 27rpx;
  font-weight: 700;
}

.continue-button {
  width: 286rpx;
  height: 82rpx;
  margin: 0;
  padding: 0 20rpx;
  border-radius: 18rpx;
  color: #ffffff;
  background: #4f7d46;
  font-size: 27rpx;
  font-weight: 600;
  line-height: 82rpx;
}

.continue-button::after {
  border: 0;
}
