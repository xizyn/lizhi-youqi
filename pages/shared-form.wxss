.form-page {
  padding: 48rpx 30rpx 72rpx;
  background: #f8f3e9;
}

.page-head {
  padding: 18rpx 0 28rpx;
}

.page-title {
  color: #25331e;
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1.25;
}

.page-subtitle {
  margin-top: 10rpx;
  color: #6f7a65;
  font-size: 25rpx;
  line-height: 1.6;
}

.notice-box {
  margin-bottom: 24rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  color: #5f6a57;
  background: #eef6e7;
  font-size: 24rpx;
  line-height: 1.7;
}

.status-banner {
  margin-bottom: 22rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  color: #385b31;
  background: #eef6e7;
}

.status-banner.danger {
  color: #8d3d38;
  background: #fff1ec;
}

.status-title {
  font-size: 28rpx;
  font-weight: 700;
}

.status-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
}

.form-card {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.field-tip {
  margin-top: 10rpx;
  color: #7c806f;
  font-size: 22rpx;
  line-height: 1.6;
}

.quick-weight-row {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 14rpx;
}

.quick-weight-button {
  height: 58rpx;
  border: 1rpx solid #d9e4d3;
  border-radius: 12rpx;
  color: #61705d;
  background: #f8fbf5;
  font-size: 23rpx;
  line-height: 58rpx;
  text-align: center;
}

.quick-weight-button.active {
  border-color: #5d8b51;
  color: #386631;
  background: #eaf4e4;
  font-weight: 600;
}

.section-title {
  margin: 12rpx 0 0;
  color: #25331e;
  font-size: 28rpx;
  font-weight: 700;
}

.sku-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.sku-card {
  overflow: hidden;
  border: 2rpx solid rgba(75, 94, 55, 0.14);
  border-radius: 22rpx;
  background: #fffdf8;
  box-sizing: border-box;
  box-shadow: 0 10rpx 26rpx rgba(57, 74, 44, 0.06);
}

.sku-card.active {
  border-color: #4f7d46;
  background: #eef6e7;
  box-shadow: 0 10rpx 24rpx rgba(69, 100, 48, 0.12);
}

.sku-card.disabled {
  opacity: 0.6;
}

.sku-image {
  display: block;
  width: 100%;
  height: 176rpx;
  background: #eef6e7;
}

.sku-content {
  padding: 18rpx 18rpx 20rpx;
}

.sku-name {
  color: #25331e;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.3;
}

.sku-desc {
  margin-top: 8rpx;
  color: #6f7a65;
  font-size: 22rpx;
  line-height: 1.4;
}

.sku-meta {
  margin-top: 8rpx;
  color: #b35048;
  font-size: 20rpx;
  line-height: 1.4;
}

.sold-meta {
  color: #8a4a3f;
}

.summary-card {
  margin-top: 4rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(75, 94, 55, 0.16);
  border-radius: 18rpx;
  background: #fffdf8;
}

.readonly-card {
  padding: 22rpx 24rpx;
  border: 1rpx solid rgba(75, 94, 55, 0.14);
  border-radius: 18rpx;
  background: #fffdf8;
}

.product-summary-card {
  display: flex;
  align-items: stretch;
  gap: 20rpx;
}

.product-summary-image {
  flex-shrink: 0;
  width: 180rpx;
  height: 150rpx;
  border-radius: 16rpx;
  background: #eef6e7;
}

.product-summary-info {
  flex: 1;
  min-width: 0;
  padding: 4rpx 0;
}

.product-summary-name {
  color: #25331e;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.35;
}

.product-summary-meta {
  margin-top: 8rpx;
  color: #6f7a65;
  font-size: 22rpx;
  line-height: 1.4;
}

.pickup-map-image {
  display: block;
  width: 100%;
  height: 260rpx;
  margin-top: 18rpx;
  border-radius: 16rpx;
  background: #eef6e7;
}

.pickup-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 18rpx;
}

.pickup-actions .mini-btn {
  flex: 1;
  margin: 0;
}

.summary-title {
  margin-bottom: 14rpx;
  color: #25331e;
  font-size: 27rpx;
  font-weight: 700;
}

.summary-line {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 8rpx 0;
  color: #5f6a57;
  font-size: 24rpx;
  line-height: 1.5;
}

.summary-value {
  color: #25331e;
  text-align: right;
}

.weight-note {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(75, 94, 55, 0.12);
  color: #6f7a65;
  font-size: 22rpx;
  line-height: 1.7;
}

.notice-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.notice-item {
  color: #5f6a57;
  font-size: 24rpx;
  line-height: 1.6;
}

.section-divider {
  height: 1rpx;
  background: rgba(75, 94, 55, 0.12);
}

.submit-button {
  width: 100%;
  height: 86rpx;
  margin-top: 6rpx;
  border: 0;
  border-radius: 999rpx;
  color: #fffdf7;
  background: #4f7d46;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 86rpx;
}

.submit-button::after {
  border: 0;
}
