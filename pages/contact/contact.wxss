.contact-page {
  min-height: 100vh;
  padding: 54rpx 30rpx 80rpx;
  background: #f8f3e9;
  box-sizing: border-box;
}

.page-head {
  padding: 16rpx 0 28rpx;
}

.page-title {
  color: #25331e;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.25;
}

.benefit-list {
  display: flex;
  flex-direction: column;
  gap: 9rpx;
  margin-top: 18rpx;
  color: #68745f;
  font-size: 24rpx;
  line-height: 1.55;
}

.benefit-list view {
  position: relative;
  padding-left: 24rpx;
}

.benefit-list view::before {
  position: absolute;
  left: 0;
  content: "•";
  color: #4f7d46;
  font-weight: 800;
}

.contact-card,
.qr-card {
  margin-top: 22rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(75, 94, 55, 0.12);
  border-radius: 24rpx;
  background: #fffdf8;
  box-shadow: 0 12rpx 30rpx rgba(57, 74, 44, 0.06);
}

.label {
  color: #6f7a65;
  font-size: 23rpx;
  line-height: 1.5;
}

.wechat-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 14rpx;
}

.wechat-id {
  color: #25331e;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.3;
  word-break: break-all;
}

.copy-btn {
  flex-shrink: 0;
  min-width: 174rpx;
  height: 64rpx;
  margin: 0;
  padding: 0 22rpx;
  border-radius: 999rpx;
  color: #fffdf8;
  background: #4f7d46;
  font-size: 24rpx;
  line-height: 64rpx;
}

.copy-btn::after {
  border: 0;
}

.qr-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  border-color: #cfe0c6;
}

.qr-image {
  width: 360rpx;
  height: 360rpx;
  border-radius: 20rpx;
  background: #eef6e7;
}

.qr-tip {
  margin-top: 18rpx;
  color: #7c806f;
  font-size: 22rpx;
  line-height: 1.6;
  text-align: center;
}

.qr-unavailable {
  min-height: 250rpx;
  justify-content: center;
  background: #f7fbf3;
}

.qr-guide-title {
  color: #6f7a65;
  font-size: 23rpx;
}

.qr-guide-id {
  margin-top: 12rpx;
  color: #315f2d;
  font-size: 38rpx;
  font-weight: 800;
  word-break: break-all;
}

.service-time {
  margin-top: 10rpx;
  color: #315f2d;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.4;
}

.desc {
  margin-top: 14rpx;
  color: #68745f;
  font-size: 24rpx;
  line-height: 1.7;
}
