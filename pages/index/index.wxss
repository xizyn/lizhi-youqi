.index-page {
  min-height: 100vh;
  padding: 18rpx 20rpx 136rpx;
  background: linear-gradient(180deg, #edf7e5 0%, #f7f3e9 56%, #f5efe4 100%);
  box-sizing: border-box;
}

.hero-card {
  position: relative;
  height: 560rpx;
  overflow: hidden;
  border-radius: 34rpx;
  background: #eef8e5;
  box-shadow: 0 18rpx 46rpx rgba(74, 96, 54, 0.16);
}

.hero-photo {
  position: absolute;
  top: 0;
  right: 0;
  width: 100%;
  height: 100%;
  border-radius: 34rpx;
}

.hero-photo-fade {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: linear-gradient(90deg, rgba(246, 251, 238, 0.98) 0%, rgba(246, 251, 238, 0.72) 42%, rgba(246, 251, 238, 0.08) 74%);
  pointer-events: none;
}

.hero-copy {
  position: absolute;
  left: 38rpx;
  right: 240rpx;
  top: 122rpx;
  z-index: 2;
}

.hero-title {
  color: #123f1d;
  font-size: 64rpx;
  font-weight: 800;
  line-height: 1.08;
  letter-spacing: 0;
}

.hero-subtitle {
  margin-top: 20rpx;
  color: #183b23;
  font-size: 29rpx;
  line-height: 1.42;
}

.hero-small {
  display: inline-flex;
  align-items: center;
  max-width: 440rpx;
  margin-top: 22rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 253, 247, 0.84);
  color: #27492b;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 1.3;
  box-shadow: 0 8rpx 18rpx rgba(82, 106, 56, 0.08);
}

.leaf-dot {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 30rpx;
  height: 30rpx;
  margin-right: 10rpx;
  border-radius: 50%;
  background: #e2f0d6;
  color: #3a7f39;
  font-size: 17rpx;
}

.hero-tip {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  bottom: 28rpx;
  z-index: 3;
  display: flex;
  align-items: center;
  min-height: 54rpx;
  padding: 10rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(255, 246, 230, 0.92);
  color: #6a5538;
  font-size: 23rpx;
  line-height: 1.35;
  box-sizing: border-box;
}

.tip-dot {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  border-radius: 50%;
  background: #eadfca;
  color: #8b744d;
  font-size: 17rpx;
}

.entry-panel {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 30rpx;
  background: rgba(255, 253, 248, 0.96);
  box-shadow: 0 14rpx 34rpx rgba(82, 106, 56, 0.08);
  box-sizing: border-box;
}

.entry-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
  min-height: 166rpx;
  padding: 16rpx 6rpx 14rpx;
  border-radius: 22rpx;
  background: #fffefb;
  box-sizing: border-box;
}

.entry-card:active,
.reminder-card:active,
.quick-card:active,
.section-card:active {
  background: #f7fbf0;
}

.icon-wrap,
.round-icon,
.quick-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  border-radius: 50%;
  background: #eaf4dd;
}

.icon-wrap {
  width: 86rpx;
  height: 86rpx;
}

.icon-disabled {
  background: #eeeeec;
  opacity: 0.68;
}

.home-icon {
  width: 58rpx;
  height: 58rpx;
}

.entry-title {
  width: 100%;
  margin-top: 16rpx;
  color: #172416;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 1.2;
  text-align: center;
}

.entry-desc {
  width: 100%;
  margin-top: 7rpx;
  color: #707a68;
  font-size: 20rpx;
  line-height: 1.25;
  text-align: center;
}

.reminder-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
  margin-top: 24rpx;
  padding: 28rpx 24rpx;
  border-radius: 26rpx;
  background: rgba(255, 253, 248, 0.98);
  box-shadow: 0 12rpx 34rpx rgba(82, 106, 56, 0.08);
  box-sizing: border-box;
}

.round-icon {
  width: 78rpx;
  height: 78rpx;
}

.small-icon {
  width: 50rpx;
  height: 50rpx;
}

.reminder-copy {
  flex: 1;
  min-width: 0;
}

.reminder-title {
  color: #172416;
  font-size: 31rpx;
  font-weight: 800;
  line-height: 1.35;
}

.reminder-text {
  margin-top: 8rpx;
  color: #404c3a;
  font-size: 24rpx;
  line-height: 1.45;
}

.reminder-button {
  flex: 0 0 auto;
  padding: 13rpx 22rpx;
  border: 1rpx solid rgba(58, 142, 69, 0.48);
  border-radius: 999rpx;
  color: #1d7530;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1;
  background: #f5fff1;
}

.quick-panel {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 22rpx;
}

.quick-card {
  position: relative;
  display: flex;
  align-items: center;
  min-width: 0;
  min-height: 142rpx;
  padding: 22rpx 44rpx 22rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 253, 248, 0.98);
  box-shadow: 0 12rpx 32rpx rgba(82, 106, 56, 0.07);
  box-sizing: border-box;
}

.quick-icon {
  width: 64rpx;
  height: 64rpx;
}

.quick-icon-img {
  width: 42rpx;
  height: 42rpx;
}

.quick-copy {
  min-width: 0;
  margin-left: 16rpx;
}

.quick-title {
  color: #172416;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.28;
}

.quick-desc {
  margin-top: 5rpx;
  color: #6f7868;
  font-size: 20rpx;
  line-height: 1.25;
}

.quick-arrow {
  position: absolute;
  right: 18rpx;
  top: 50%;
  color: #61815a;
  font-family: Arial, sans-serif;
  font-size: 38rpx;
  line-height: 1;
  transform: translateY(-50%);
}

.section-card {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background: rgba(255, 253, 248, 0.98);
  box-shadow: 0 12rpx 34rpx rgba(82, 106, 56, 0.08);
  box-sizing: border-box;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.section-title {
  color: #172416;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.3;
}

.section-tag {
  flex: 0 0 auto;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #e5f4dd;
  color: #2e7d37;
  font-size: 21rpx;
  font-weight: 700;
}

.supply-products {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 22rpx;
}

.supply-item {
  display: flex;
  align-items: center;
  min-width: 0;
  padding: 12rpx;
  border-radius: 18rpx;
  background: linear-gradient(90deg, #f4faec 0%, #fffdf8 100%);
  box-sizing: border-box;
}

.supply-image {
  flex: 0 0 auto;
  width: 104rpx;
  height: 104rpx;
  border-radius: 16rpx;
  background: #edf3e5;
}

.supply-info {
  min-width: 0;
  margin-left: 16rpx;
}

.supply-name {
  color: #1c2c19;
  font-size: 27rpx;
  font-weight: 800;
  line-height: 1.25;
}

.supply-desc {
  margin-top: 8rpx;
  color: #687463;
  font-size: 21rpx;
  line-height: 1.35;
}

.supply-tags {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  margin-top: 22rpx;
}

.supply-tag {
  flex: 1;
  min-width: 0;
  color: #2b5c31;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.25;
  text-align: center;
}

.supply-time {
  margin-top: 22rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: #f4f0e6;
  color: #257137;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1.35;
  text-align: center;
}

.orchard-photos {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 22rpx;
}

.orchard-photo {
  width: 100%;
  height: 158rpx;
  border-radius: 16rpx;
  background: #edf3e5;
}

.orchard-note {
  margin-top: 18rpx;
  color: #5e6a58;
  font-size: 24rpx;
  line-height: 1.45;
}
