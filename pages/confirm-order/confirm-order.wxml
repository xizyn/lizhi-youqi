<view class="confirm-page">
  <view class="brand-card">
    <image class="brand-image" src="/assets/images/banner-lychee.png" mode="aspectFill"></image>
    <view class="brand-shade"></view>
    <view class="brand-copy">
      <text class="brand-name">荔枝有期</text>
      <text class="brand-subtitle">深圳本地自家果园 · 成熟后现摘</text>
    </view>
  </view>

  <view class="section-card delivery-card">
    <view class="section-icon">送</view>
    <view class="section-main">
      <view class="section-title-row">
        <text class="section-title">{{deliveryName}}</text>
        <text class="change-link" bindtap="editOrder">可更改</text>
      </view>
      <text class="section-desc">{{deliveryDescription}}</text>
    </view>
  </view>

  <view class="section-card">
    <view class="card-heading">商品信息</view>
    <view class="product-row">
      <image class="product-image" src="{{productImage}}" mode="aspectFill"></image>
      <view class="product-info">
        <text class="product-name">{{productName}}</text>
        <text class="product-spec">{{specification}}</text>
        <view class="product-bottom">
          <text class="product-price">¥{{unitPriceText}}</text>
          <view wx:if="{{quantityEditable}}" class="stepper">
            <button class="stepper-button" bindtap="decreaseQuantity">−</button>
            <text class="stepper-value">{{quantity}}</text>
            <button class="stepper-button" bindtap="increaseQuantity">＋</button>
          </view>
          <text wx:else class="fixed-quantity">1份（按斤）</text>
        </view>
      </view>
    </view>
  </view>

  <view class="section-card">
    <view class="section-title-row">
      <text class="card-heading">收货信息</text>
      <text class="change-link" bindtap="editOrder">修改</text>
    </view>
    <view class="recipient-line">
      <text class="recipient-name">{{recipient.name}}</text>
      <text class="recipient-phone">{{recipient.phone}}</text>
    </view>
    <text class="recipient-address">{{recipient.address}}</text>
  </view>

  <view class="section-card fee-card">
    <view class="card-heading">费用明细</view>
    <view class="fee-row">
      <text>商品金额</text>
      <text>¥{{productAmountText}}</text>
    </view>
    <view class="fee-row">
      <text>{{hasReferenceShipping ? '参考运费' : '配送费用'}}</text>
      <text>{{hasReferenceShipping ? referenceShippingFeeText : (shippingFeeText === '0.00' ? '客服确认' : '¥' + shippingFeeText)}}</text>
    </view>
    <view wx:if="{{giftBoxFeeText !== '0.00'}}" class="fee-row">
      <text>礼盒费用</text>
      <text>¥{{giftBoxFeeText}}</text>
    </view>
    <view class="fee-row interactive-row" bindtap="openCouponSheet">
      <view>
        <text>优惠券</text>
        <text class="fee-hint">{{selectedCouponName}}</text>
      </view>
      <view class="fee-action">
        <text wx:if="{{couponValueText}}" class="discount-text">{{couponValueText}}</text>
        <text class="chevron">›</text>
      </view>
    </view>
    <view class="fee-row points-row">
      <view>
        <text>积分抵扣</text>
        <text class="fee-hint">{{pointsHint}}</text>
      </view>
      <switch checked="{{usePoints}}" disabled="{{usablePoints <= 0}}" color="#5b8a4a" bindchange="togglePoints"></switch>
    </view>
    <view class="fee-row total-line">
      <text>{{hasReferenceShipping ? '商品及已确定费用' : '合计'}}</text>
      <text>¥{{subtotalText}}</text>
    </view>
    <view wx:if="{{couponDiscountText !== '0.00' || pointsDiscountText !== '0.00'}}" class="discount-summary">
      <text>优惠券 -¥{{couponDiscountText}}</text>
      <text>积分 -¥{{pointsDiscountText}}</text>
    </view>
    <view class="payable-row">
      <text class="payable-label">{{hasReferenceShipping ? '预估合计' : '应付金额'}}</text>
      <text class="payable-value">{{hasReferenceShipping ? estimatedPayableRangeText : '¥' + payableAmountText}}</text>
    </view>
    <view class="reference-tip" wx:if="{{hasReferenceShipping}}">预估合计仅供参考，实际金额以发货前确认及顺丰实际结算为准。</view>
  </view>

  <view class="tips-card">
    <text class="tips-title">温馨提示</text>
    <text class="tips-item">· 提交订单后将进入“待付款”状态</text>
    <text class="tips-item">· 当前阶段暂不接入微信在线支付</text>
    <text class="tips-item">{{isExpressOrder ? '· 等待客服确认库存、运费和发货时间后再联系付款' : '· 农户确认库存和发货安排后再联系付款'}}</text>
  </view>

  <view class="bottom-placeholder"></view>

  <view class="settlement-bar">
    <view class="settlement-total">
      <text class="settlement-label">{{hasReferenceShipping ? '预估合计' : '合计'}}</text>
      <text class="settlement-price">{{hasReferenceShipping ? estimatedPayableRangeText : '¥' + payableAmountText}}</text>
    </view>
    <button class="submit-button" loading="{{submitting}}" disabled="{{submitting}}" bindtap="submitOrder">提交订单</button>
  </view>

  <view wx:if="{{showCouponSheet}}" class="sheet-mask" bindtap="closeCouponSheet">
    <view class="coupon-sheet" catchtap="stopPropagation">
      <view class="sheet-header">
        <text class="sheet-title">选择优惠券</text>
        <text class="sheet-close" bindtap="closeCouponSheet">×</text>
      </view>
      <scroll-view class="coupon-list" scroll-y>
        <view class="coupon-option {{selectedCouponRecordId === '' ? 'selected' : ''}}" data-id="" bindtap="chooseCoupon">
          <view>
            <text class="coupon-name">不使用优惠券</text>
            <text class="coupon-condition">按订单原价结算</text>
          </view>
          <text class="coupon-check">{{selectedCouponRecordId === '' ? '✓' : ''}}</text>
        </view>
        <view wx:for="{{availableCoupons}}" wx:key="recordId" class="coupon-option {{selectedCouponRecordId === item.recordId ? 'selected' : ''}}" data-id="{{item.recordId}}" bindtap="chooseCoupon">
          <view>
            <text class="coupon-name">{{item.couponName}}</text>
            <text class="coupon-condition">{{item.conditionText}} · {{item.applyScene}}</text>
          </view>
          <view class="coupon-right">
            <text class="coupon-discount">{{item.discountText}}</text>
            <text class="coupon-check">{{selectedCouponRecordId === item.recordId ? '✓' : ''}}</text>
          </view>
        </view>
        <view wx:if="{{availableCouponCount === 0}}" class="empty-coupon">当前订单暂无可用优惠券</view>
      </scroll-view>
    </view>
  </view>
</view>
