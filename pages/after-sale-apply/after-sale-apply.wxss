page { background: #f8f3e9; }
.apply-page { padding-bottom: 100rpx; }
.order-card, .form-card { margin-bottom: 20rpx; padding: 26rpx; border: 1rpx solid rgba(79,125,70,.11); border-radius: 20rpx; background: #fffdf7; box-shadow: 0 10rpx 26rpx rgba(74,91,58,.05); }
.card-title { color: #25331e; font-size: 30rpx; font-weight: 800; }
.order-no { margin-top: 14rpx; color: #687163; font-size: 22rpx; }
.product-name { margin-top: 10rpx; color: #25331e; font-size: 29rpx; font-weight: 800; }
.info-grid { display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); gap: 12rpx; margin-top: 20rpx; }
.info-grid view { display: flex; flex-direction: column; gap: 5rpx; padding: 14rpx; border-radius: 12rpx; background: #f4f8ef; color: #3d4938; font-size: 22rpx; }
.info-grid text:first-child { color: #7a826f; font-size: 20rpx; }
.deadline { margin-top: 18rpx; color: #9b6920; font-size: 22rpx; }
.choice-grid { display: grid; grid-template-columns: repeat(2,minmax(0,1fr)); gap: 12rpx; margin-top: 20rpx; }
.method-grid { grid-template-columns: repeat(3,minmax(0,1fr)); }
.choice { display: flex; align-items: center; justify-content: center; min-height: 68rpx; padding: 10rpx; border: 1rpx solid #dfe4da; border-radius: 12rpx; color: #697264; background: #fff; font-size: 22rpx; text-align: center; }
.choice.selected { border-color: #4f7d46; color: #315f2d; background: #eaf4e3; font-weight: 700; }
.title-row { display: flex; align-items: center; justify-content: space-between; }
.counter { color: #8a9183; font-size: 21rpx; }
.description-input { width: 100%; min-height: 210rpx; margin-top: 18rpx; padding: 20rpx; border: 1rpx solid #e1e5dd; border-radius: 14rpx; color: #30392e; background: #fff; font-size: 25rpx; }
.evidence-tip { margin-top: 10rpx; color: #7a826f; font-size: 21rpx; line-height: 1.55; }
.image-grid { display: grid; grid-template-columns: repeat(3,minmax(0,1fr)); gap: 14rpx; margin-top: 20rpx; }
.image-item { position: relative; aspect-ratio: 1; overflow: hidden; border-radius: 12rpx; background: #eef2e9; }
.image-item image { width: 100%; height: 100%; }
.remove { position: absolute; right: 0; bottom: 0; padding: 5rpx 10rpx; color: #fff; background: rgba(58,46,40,.72); font-size: 18rpx; }
.add-image { display: flex; aspect-ratio: 1; flex-direction: column; align-items: center; justify-content: center; border: 1rpx dashed #a8b99e; border-radius: 12rpx; color: #5d7854; background: #f4f8ef; font-size: 20rpx; }
.add-symbol { font-size: 42rpx; line-height: 1; }
.rule-note { padding: 22rpx; border-radius: 16rpx; color: #687163; background: #eef5e8; font-size: 21rpx; line-height: 1.55; }
.rule-link { margin-top: 10rpx; color: #3f7335; font-weight: 700; }
.submit-btn { height: 86rpx; margin-top: 24rpx; border-radius: 999rpx; color: #fff; background: #4f7d46; font-size: 28rpx; font-weight: 800; line-height: 86rpx; }
.submit-btn::after { border: 0; }
.submit-btn[disabled] { color: rgba(255,255,255,.82); background: #88a681; }
