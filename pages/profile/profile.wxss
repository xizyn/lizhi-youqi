.profile-page {
  padding: 48rpx 30rpx 150rpx;
  background: #faf5eb;
}

.profile-head {
  padding: 28rpx 0 18rpx;
  text-align: center;
}

.profile-title {
  color: #273323;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.25;
}

.member-card {
  padding: 30rpx 24rpx;
  border: 1rpx solid rgba(82, 111, 65, 0.1);
  border-radius: 24rpx;
  background: linear-gradient(135deg, #eef7e8 0%, #f8fbf2 100%);
  box-shadow: 0 14rpx 34rpx rgba(76, 94, 56, 0.1);
}

.member-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.member-avatar {
  width: 104rpx;
  height: 104rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.78);
  border-radius: 50%;
  background: #e8f2df;
}

.member-main {
  flex: 1;
  min-width: 0;
}

.member-name-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.member-name {
  color: #25331e;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.35;
}

.member-tag {
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
  color: #4f7d46;
  background: #e2f1d9;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.25;
}

.member-tag.admin-tag-true {
  color: #b37615;
  background: #fff1d5;
}

.member-code {
  margin-top: 8rpx;
  color: #5f6858;
  font-size: 25rpx;
  line-height: 1.45;
}

.stats-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 4rpx;
  margin-top: 30rpx;
}

.stat-item {
  padding: 22rpx 8rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.86);
  text-align: center;
}

.stat-label {
  color: #5f6858;
  font-size: 22rpx;
  line-height: 1.35;
}

.stat-value {
  margin-top: 10rpx;
  color: #2f7d42;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.2;
}

.profile-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 18rpx;
}

.orders-card {
  margin-top: 22rpx;
  padding: 26rpx 24rpx;
  border: 1rpx solid rgba(82, 111, 65, 0.11);
  border-radius: 20rpx;
  background: #fffdf7;
  box-shadow: 0 10rpx 26rpx rgba(80, 96, 62, 0.06);
}

.orders-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.orders-title {
  color: #25331e;
  font-size: 29rpx;
  font-weight: 800;
}

.orders-desc,
.orders-all {
  margin-top: 6rpx;
  color: #7a826f;
  font-size: 22rpx;
}

.orders-all {
  color: #4f7d46;
}

.order-shortcuts {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  margin-top: 24rpx;
}

.order-shortcut {
  min-width: 0;
  padding: 12rpx 4rpx;
  border-right: 1rpx solid rgba(82, 111, 65, 0.1);
  text-align: center;
}

.order-shortcut:last-child {
  border-right: 0;
}

.shortcut-count {
  color: #2f7d42;
  font-size: 32rpx;
  font-weight: 800;
}

.shortcut-label {
  margin-top: 8rpx;
  color: #626b5d;
  font-size: 21rpx;
}

.reminder-list {
  margin-top: 18rpx;
}

.reminder-link {
  border-color: rgba(79, 125, 70, 0.18);
  background: linear-gradient(135deg, #f0f7eb 0%, #fffdf7 100%);
}

.entry-status {
  flex: 0 0 auto;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  color: #4f7d46;
  background: #e7f3df;
  font-size: 20rpx;
  font-weight: 700;
}

.status-warning {
  color: #9a6b26;
  background: #fff0d2;
}

.status-muted {
  color: #7d8378;
  background: #eef0eb;
}

.profile-link,
.admin-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 26rpx 24rpx;
  border: 1rpx solid rgba(82, 111, 65, 0.12);
  border-radius: 18rpx;
  background: #fffdf7;
  box-shadow: 0 10rpx 26rpx rgba(80, 96, 62, 0.06);
}

.admin-card {
  margin-top: 24rpx;
  border-color: rgba(79, 125, 70, 0.16);
  background: linear-gradient(135deg, #eef7e9 0%, #fffdf7 100%);
}

.entry-icon {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
  border: 3rpx solid #2f7d42;
  border-radius: 16rpx;
  color: #2f7d42;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1;
}

.admin-icon {
  color: #fffdf7;
  background: #4f7d46;
}

.entry-main {
  flex: 1;
  min-width: 0;
}

.link-title {
  color: #25331e;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 1.35;
}

.link-desc {
  margin-top: 8rpx;
  color: #7a826f;
  font-size: 23rpx;
  line-height: 1.45;
}

.link-arrow {
  flex: 0 0 auto;
  color: #a2aa98;
  font-size: 42rpx;
  line-height: 1;
}

.profile-footer {
  margin-top: 36rpx;
  color: #9a9f90;
  font-size: 24rpx;
  text-align: center;
}
